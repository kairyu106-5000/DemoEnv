    {
        "id": "96b640946f50dbd9",
        "type": "function",
        "z": "51941ff1083ce014",
        "name": "calc_R",
        "func": "let red_delta = msg.payload.Red_deltaA\nlet ir_delta = msg.payload.Ir_deltaA\n\nif(ir_delta == 0){\n    ir_delta = 0.000001\n}\n\nconst R = red_delta / ir_delta;\n\nmsg.payload = R\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1150,
        "y": 320,
        "wires": [
            [
                "8d3b0bb4c024e92d"
            ]
        ]
    },
    {
        "id": "a5c475c5f47aab68",
        "type": "function",
        "z": "51941ff1083ce014",
        "name": "parse_PPG_data",
        "func": "let input = msg.payload;\nlet tlen = msg.Ndata.Len;\nlet hubDate = msg.hubDate\n\nconst BUFFER_SIZE = 3;\nconst samplingTime = 40; // ms\n\nif (tlen == 0) {\n    return null;\n}\n// ======= Nodeタイムスタンプ管理用 ======= \nconst contextName = {\n    // Hubのタイムスタンプを使用する\n    startDate: \"$parent.startDate_\" + msg.port,\n    startTime: \"$parent.startTime_\" + msg.port,\n}\n\nconst getCurrentDate = (timeStamp) => {\n    let startDate = flow.get(contextName.startDate)\n    let startTime = flow.get(contextName.startTime)\n    let diffTime = timeStamp - startTime\n    let currentDate = new Date(startDate + diffTime)\n    return currentDate\n}\n\n// ========================================================\n\nlet timeValue = parseInt(input[0] + input[1] + input[2] + input[3], 16)\n\n// contextデータを使用して時刻を算出する\nlet headDate = getCurrentDate(timeValue)\n\nlet ppgBuffer = input.slice(4)\nlet buffer = new Array()\n// lenのサイズに従ってBuffer配列を作成する\nfor (let cnt = 0; cnt < tlen; cnt++) {\n    buffer[cnt] = new Array()\n    for (let i = 0; i < BUFFER_SIZE; i++) {\n        buffer[cnt].push(ppgBuffer[i + BUFFER_SIZE * cnt])\n    }\n}\n\nfor (let cnt = 0; cnt<tlen; cnt++) {\n    let ppgValue = parseInt(buffer[cnt][0] + buffer[cnt][1] + buffer[cnt][2],16)\n    if (ppgValue & 0x800000) ppgValue |= ~0xffffff; //24bit\n    \n    let measurementTime = new Date(headDate.getTime() + (samplingTime * cnt))\n    msg = {\n        Ndata: msg.Ndata,\n        payload: {\n            ppg: ppgValue,\n            Ndata: msg.Ndata,\n            timestamp: measurementTime\n        },\n        timestamp: measurementTime,\n        samplingTime: samplingTime,\n    }\n    node.send(msg);\n}\n\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 190,
        "y": 60,
        "wires": [
            []
        ]
    },
