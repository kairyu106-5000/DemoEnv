    {
        "id": "a0194c66f78d9a6a",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "batch_peak_detection",
        "func": "let dataArr = msg.payload\n\n// node.log(\"data: \" + JSON.stringify(dataArr))\n\n// 前後比較するインデックスの配列を作成する(1から開始、後ろから2番目まで)\nlet baseId = Array.from({length: (dataArr.length-2)},(_, i)=> i+1)\nlet peakLoc = baseId.filter((index) =>{\n    return dataArr[index].ecg > dataArr[index - 1].ecg && dataArr[index].ecg > dataArr[index + 1].ecg\n})\nif(peakLoc){\n    peakLoc.map(index=>{\n        msg = {\n            payload: dataArr[index].ecg,\n            timestamp: dataArr[index].timestamp,\n            Ndata: dataArr[index].Ndata\n        }\n        node.send(msg)\n    })\n    node.done()\n}else{\n    return null\n}\n// let peakData = peakLoc.map(index=> dataArr[index])\n\n// for (let i=0, length = peakData.length; i<length;i++){\n//     msg = {\n//         payload: peakData[i].ecg,\n//         timestamp: peakData[i].timestamp,\n//         Ndata: peakData[i].Ndata\n//     }\n//     node.send(msg);\n// }\n\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 180,
        "y": 1100,
        "wires": [
            [
                "c5e82caa96fc2966"
            ]
        ]
    },
    {
        "id": "e540a8ad946fa1c6",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "calc_HeartRate",
        "func": "let currentDate = msg.timestamp\n\nlet preDate = context.get(\"preDate\")\n\nif(!preDate){\n    context.set(\"preDate\",currentDate)\n    return null\n}\n\nlet RRI = currentDate.getTime() - preDate.getTime()\n\nlet BPM = 1000*60 / RRI\nBPM = Math.trunc(BPM)\n// node.log(\"RRI= \" + RRI + \" ms\")\n// node.log(\"BPM= \" + BPM)\n\nmsg.payload = {\n    HR: BPM,\n    RRI: RRI,\n}\ncontext.set(\"preDate\", currentDate)\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 200,
        "y": 1180,
        "wires": [
            [
                "e2ded76d34733038"
            ]
        ]
    },
    {
        "id": "af3c1648ffcc024c",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "prepareSendData_for_influxdb",
        "func": "msg.ResultTime = new Date()\n\nconst dataArr = msg.payload\n\n// ========== payload作成 ==========\nmsg.payload = {\n    // You bucket\n    // Optional (it can be defined in the node credentials settings)\n    bucket: 'node-data',\n\n    // Precision of timestamp\n    // Optional\n    // Can be `ns` (nanoseconds),\n    //        `us` (microseconds),\n    //        `ms` (milliseconds),\n    //        `s` (seconds).\n    // The default is `ns`\n    // Note: if you set the `timestamp` field to `Date.now()`, you have to set the `precision` to `ms`\n    precision: 'ms',\n\n    // Data to send to InfluxDB\n    // Can be an array of objects or only one object\n    data: msg.payload\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1050,
        "y": 340,
        "wires": [
            [
                "96aaedadd0c1e58f"
            ]
        ]
    },
    {
        "id": "4b47cbc8ddc63c8d",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "FFT_filter",
        "func": "// ================ define function ================\nconst expi = (theta) =>{\n    return [Math.cos(theta), Math.sin(theta)]\n}\nconst iadd = ([ax, ay],[bx, by])=>{\n    return [ax + bx, ay + by]\n}\nconst isub = ([ax, ay], [bx, by]) =>{\n    return [ax - bx, ay - by]\n}\nconst imul = ([ax,ay],[bx,by]) =>{\n    return [ax*bx - ay*by, ax*by + ay*bx]\n}\nconst isum = (cs) =>{\n    return cs.reduce((s,c) => iadd(s,c), [0,0])\n}\n\n/* calc fft by recursive function*/\nconst fftrec = (c, T, N, s=0, w=1) =>{\n    if(N === 1) return [c[s]];\n    const Nh = N/2, Td = T*2, wd = w*2;\n    const rec = fftrec(c, Td, Nh, s, wd).concat(fftrec(c, Td, Nh, s+w, wd));\n    for(let i=0; i<Nh; i++){\n        const l = rec[i], re= imul(rec[i+Nh],expi(T*i));\n        [rec[i], rec[i+Nh]] = [iadd(l, re), isub(l, re)];\n    }\n    return rec\n}\n\nconst fft0 = (f) =>{\n    const N = f.length, T = -2 * Math.PI / N;\n    return fftrec(f,T,N)\n}\n\nconst ifft0 = (F) =>{\n    const N = F.length, T = 2 * Math.PI / N;\n    return fftrec(F, T, N).map(([r, i])=> [r/N, i/N])\n}\n\nconst calcPowerSpectrum = (f, resolution) =>{\n    return f.map((r, index) => [(resolution * index).toPrecision(6),Math.sqrt(r[0]**2 + r[1]**2)])\n}\n\n// ================================================\n\n/**\n *  横軸分解能\n *  ΔHz = 1/(2^N * Δt) \n *  \n */\n\nlet input = msg.payload\nlet timestamp = msg.timestamp\nlet samplingTime = msg.samplingTime\n\nconst f_resolution = 1 / (input.length * samplingTime/1000)\n// const f_resolution = 1 / (input.length * 0.2)\n\nlet accXArr=[], accYArr=[], accZArr=[];\ninput.map((r)=> {\n    accXArr.push([r[\"acc_x\"], 0]);\n    accYArr.push([r[\"acc_y\"], 0]);\n    accZArr.push([r[\"acc_z\"], 0]);\n});\n\nconst F_accX = fft0(accXArr)\nconst F_accY = fft0(accYArr)\nconst F_accZ = fft0(accZArr)\n\nconst acc_x_PS = calcPowerSpectrum(F_accX, f_resolution)\nconst acc_y_PS = calcPowerSpectrum(F_accY, f_resolution)\nconst acc_z_PS = calcPowerSpectrum(F_accZ, f_resolution)\n\nlet acc_x_PS_obj = {}\nlet acc_y_PS_obj = {}\nlet acc_z_PS_obj = {}\n\nacc_x_PS.map((r)=> acc_x_PS_obj[r[0]] = r[1])\nacc_y_PS.map((r) => acc_y_PS_obj[r[0]] = r[1])\nacc_z_PS.map((r) => acc_z_PS_obj[r[0]] = r[1])\n\nlet acc_x_PSD = {}\nlet acc_y_PSD = {}\nlet acc_z_PSD = {}\n\nconst offset = 1e-10\n\nacc_x_PS.map((r) => acc_x_PSD[r[0]] = 10 * Math.log10(r[1] / f_resolution + offset))\nacc_y_PS.map((r) => acc_y_PSD[r[0]] = 10 * Math.log10(r[1] / f_resolution + offset))\nacc_z_PS.map((r) => acc_z_PSD[r[0]] = 10 * Math.log10(r[1] / f_resolution + offset))\n\nmsg = {\n    payload:{\n        acc_x_PS: acc_x_PS_obj,\n        acc_y_PS: acc_y_PS_obj,\n        acc_z_PS: acc_z_PS_obj,\n        acc_x_PSD: acc_x_PSD,\n        acc_y_PSD: acc_y_PSD,\n        acc_z_PSD: acc_z_PSD,\n        F_x: F_accX,\n        F_y: F_accY,\n        F_z: F_accZ\n    },\n    timestamp: timestamp,\n    Ndata: msg.Ndata\n}\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1260,
        "y": 1120,
