    {
        "id": "6662ce01c7f7d6fa",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "calc_LFHF",
        "func": "// =================================\n// パワースペクトル密度の入力を受け取る\n// 入力データからキーである周波数のリストを取り出す\n// 周波数リストを文字列から数値に変換する\n// 周波数リストからLF(0.05Hz~0.15Hzまで)に該当するインデックスを取り出す\n// 周波数リストからHF(0.15Hz~0.40Hzまで)に該当するインデックスを取り出す\n// 各領域のインデックスを用いて積分値を算出する\n// LF / HFを計算し、ストレス指標とする\n// =================================\n\nconst VLFRANGE = [0, 0.05]      // 低周波数成分\nconst LFRANGE = [0.05, 0.15]    // 中間周波数成分\nconst HFRANGE = [0.15, 0.40]    // 高周波数成分\n\nlet input = msg.payload\n\n// PSDのオブジェクトからキーとバリューをリストにして取り出す\nlet hzKeys = Object.keys(input)\nlet hzValues = Object.values(input)\n\nlet hzList = []\nhzKeys.map(str => hzList.push(parseFloat(str)))\n\n// ========= 積分計算 =========\n\n// [WIP]単純な加算しか行っていないため、正確に積分値を計算する場合には修正が必要\n\nlet HF = 0\nlet LF = 0\nhzList.map((value, index)=>{\n    if((value >= LFRANGE[0]) &&(value <= LFRANGE[1])){\n        LF += hzValues[index]\n    }\n    if ((value > HFRANGE[0]) && (value <= HFRANGE[1])) {\n        HF += hzValues[index]\n    }\n})\n\nlet LFHF\n\nif(HF == 0){\n    const offset = 1e-10\n    LFHF = LF / (HF + offset)\n} else{\n    LFHF = LF / HF\n}\n\nmsg.payload= {\n    LF: LF,\n    HF: HF,\n    LFHF: LFHF\n}\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 610,
        "y": 1180,
        "wires": [
            [
                "d7f167fe7d0d7b0f"
            ]
        ]
    },
