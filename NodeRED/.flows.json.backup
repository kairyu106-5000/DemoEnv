    {
        "id": "b473b2e1d9191a51",
        "type": "function",
        "z": "007a7381dc88608d",
        "name": "calc_Hum",
        "func": "let adc_H = msg.payload.humidity\nlet t_fine = msg.payload.t_fine\n\n// ----- calibration setting -----\n// const dig_H1 = parseInt(flow.get(\"dig_H1\"), 16)\n// const dig_H2 = parseInt(flow.get(\"dig_H2\"), 16)\n// const dig_H3 = parseInt(flow.get(\"dig_H3\"), 16)\n// const dig_H4 = parseInt(flow.get(\"dig_H4\"), 16)\n// const dig_H5 = parseInt(flow.get(\"dig_H5\"), 16)\n// const dig_H6 = parseInt(flow.get(\"dig_H6\"), 16)\n\nconst dig_H1 = msg.calib.dig_H1\nconst dig_H2 = msg.calib.dig_H2\nconst dig_H3 = msg.calib.dig_H3\nconst dig_H4 = msg.calib.dig_H4\nconst dig_H5 = msg.calib.dig_H5\nconst dig_H6 = msg.calib.dig_H6\n\n//calc Humidity\nlet v_x1 = (t_fine - (76800));\nv_x1 = (((((adc_H << 14) - ((dig_H4) << 20) - ((dig_H5) * v_x1)) + (16384)) >> 15) * (((((((v_x1 * (dig_H6)) >> 10) * (((v_x1 * (dig_H3)) >> 11) + (32768))) >> 10) + (2097152)) * (dig_H2) + 8192) >> 14));\nv_x1 = (v_x1 - (((((v_x1 >> 15) * (v_x1 >> 15)) >> 7) * (dig_H1)) >> 4));\nv_x1 = (v_x1 < 0 ? 0 : v_x1);\nv_x1 = (v_x1 > 419430400 ? 419430400 : v_x1);\n\nlet humi_cal = v_x1 >> 12\n\nconst humi = humi_cal / 1024.0\n\nmsg.payload = humi\n\nreturn msg;\n\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1120,
        "y": 260,
        "wires": [
            []
        ]
    },
    {
        "id": "d0df420b0522b56f",
        "type": "function",
        "z": "007a7381dc88608d",
        "name": "calc_Press",
        "func": "let adc_P = msg.payload.pressure\nconst t_fine = msg.payload.t_fine\n\n// ----- calibration setting -----\n// const dig_P1 = parseInt(flow.get(\"dig_P1\"), 16)\n// const dig_P2 = parseInt(flow.get(\"dig_P2\"), 16)\n// const dig_P3 = parseInt(flow.get(\"dig_P3\"), 16)\n// const dig_P4 = parseInt(flow.get(\"dig_P4\"), 16)\n// const dig_P5 = parseInt(flow.get(\"dig_P5\"), 16)\n// const dig_P6 = parseInt(flow.get(\"dig_P6\"), 16)\n// const dig_P7 = parseInt(flow.get(\"dig_P7\"), 16)\n// const dig_P8 = parseInt(flow.get(\"dig_P8\"), 16)\n// const dig_P9 = parseInt(flow.get(\"dig_P9\"), 16)\n\nconst dig_P1 = msg.calib.dig_P1\nconst dig_P2 = msg.calib.dig_P2\nconst dig_P3 = msg.calib.dig_P3\nconst dig_P4 = msg.calib.dig_P4\nconst dig_P5 = msg.calib.dig_P5\nconst dig_P6 = msg.calib.dig_P6\nconst dig_P7 = msg.calib.dig_P7\nconst dig_P8 = msg.calib.dig_P8\nconst dig_P9 = msg.calib.dig_P9\n\n// calc Pressure\nlet var1 = (t_fine >> 1) - 64000;\nlet var2 = (((var1 >> 2) * (var1 >> 2)) >> 11) * dig_P6;\nvar2 = var2 + ((var1 * dig_P5) << 1);\nvar2 = (var2 >> 2) + (dig_P4 << 16);\nvar1 = (((dig_P3 * (((var1 >> 2) * (var1 >> 2)) >> 13)) >> 3) + ((dig_P2 * var1) >> 1)) >> 18;\nvar1 = ((((32768 + var1)) * dig_P1) >> 15);\nif (var1 == 0) {\n    return 0;\n}\nlet P = (((1048576 - adc_P) - (var2 >> 12))) * 3125;\nif (P < 0x80000000) {\n    P = (P << 1) / var1;\n} else {\n    P = (P / var1) * 2;\n}\nvar1 = (dig_P9 * ((((P >> 3) * (P >> 3)) >> 13))) >> 12;\nvar2 = (((P >> 2)) * dig_P8) >> 13;\nP = (P + ((var1 + var2 + dig_P7) >> 4));\n\nconst pres = P / 100.0\n\nmsg.payload = pres\n\nreturn msg;\n\n",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1130,
        "y": 320,
        "wires": [
            []
        ]
    },
