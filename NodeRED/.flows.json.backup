    {
        "id": "13158c262ae9d34a",
        "type": "function",
        "z": "51941ff1083ce014",
        "name": "calc_SpO2",
        "func": "let red_delta = msg.payload.Red_deltaA\nlet ir_delta = msg.payload.Ir_deltaA\n\nif (ir_delta == 0){\n    ir_delta = 0.000001\n}\n\nconst calcSpo2 = (red_delta, ir_delta) => {\n    // const R = Math.round(red_ac / red_dc) / Math.round(ir_ac / ir_dc);\n    const R = red_delta / ir_delta;\n    const a = -45.06;\n    const b = 30.354;\n    const c = 94.845;\n\n    const res = a * R * R + b * R + c;\n    return res;\n}\n\nlet spo2 = calcSpo2(red_delta, ir_delta)\nspo2 = spo2.toPrecision(5)\n\nmsg.payload = spo2\n// msg.payload = {\n//     \"SpO2\": spo2,\n//     \"Red_d\": red_delta,\n//     \"Ir_d\": ir_delta\n// }\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1170,
        "y": 260,
        "wires": [
            []
        ]
    },
