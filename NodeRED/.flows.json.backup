    {
        "id": "bf88faaddfc768bc",
        "type": "subflow:007a7381dc88608d",
        "z": "b6720ac1884745ba",
        "d": true,
        "name": "",
        "x": 890,
        "y": 1060,
        "wires": [
            [],
            [],
            []
        ],
        "info": "Temperature, Humidity, Pressureを\r\nNode-RED側で計算させるためのサブフロー\r\n"
    },
    {
        "id": "ed85c17c91f1fad0",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "read_ReData",
        "func": "// バッファからの文字列変換\n//msg.payload = msg.payload.toString('utf8');\n//msg.payload = {payload:msg.payload.toString('ASCII')};\nvar string = msg.payload;\n//var fit = \"ReData\";\nvar fit = \"Container\";\n\n/** context名を管理するオブジェクト */\nconst contextName = {\n    startDate: \"startDate_\" + msg.port,\n    startTime: \"startTime_\" + msg.port,\n    preTime: \"preTime_\" + msg.port,\n}\n\n//msg.payload = null;\n// データの検証\nif (!msg.payload) {\n    return null;\n}\n\n/** 指定した時刻とタイムスタンプ値を紐づけてcontextに保存する関数 */\nconst setStartDate = (now, timestamp) =>{\n    flow.set(contextName.startDate, now.getTime())\n    flow.set(contextName.startTime, timestamp)\n    node.log(\"startDate set is complete. startDate: \" + now.getTime())\n} \n\n/** タイムスタンプから時刻を算出する関数 */\nconst getCurrentDate = (timeStamp) => {\n    const startDate = flow.get(contextName.startDate)\n    const startTime = flow.get(contextName.startTime)\n    let diffTime = timeStamp - startTime\n    let currentDate = new Date(startDate + diffTime)\n    return currentDate\n}\n\nif (~string.indexOf(fit)) {                      // \"ReData\"一致時の処理\n    //var result = string.split('ReData:');        //Redata:で分割\n    var result = string.split('Container:');        //Container:で分割\n    var answer = result[1];\n    if (answer == null) { return null; }\n\n    var result = answer.split('<<');        //<<で分割\n    if (result.length == null) { return null; }\n\n    //var answer = result[0].trim().split(' ');                //' 'で分割\n    var answer = result[0].split(' ');\n  \n    //let timestamp = parseInt(answer[7] + answer[8] + answer[9] + answer[10],16)\n    let timestamp = parseInt(answer[29] + answer[30] + answer[31] + answer[32], 16)\n    \n    /* ==== 取得時刻とタイムスタンプを同期させる処理 ==== */\n    \n    const now = new Date()\n\n    // contextデータの取得\n    let startDate = flow.get(contextName.startDate)\n    let startTime = flow.get(contextName.startTime)\n    let preTime = flow.get(contextName.preTime)\n\n    // context未設定時にリセット\n    if ((!startDate) || (!startTime)) {\n        setStartDate(now, timestamp);\n    }\n    // 前回のタイムスタンプより値が小さい場合にリセット\n    if (timestamp < preTime) {\n        setStartDate(now, timestamp);\n    }\n    \n    // タイムスタンプからHubの時刻を算出する\n    let hubDate = getCurrentDate(timestamp)\n    \n    // contextに今回のタイムスタンプを保存する\n    flow.set(contextName.preTime,timestamp)\n    \n    /* ============================================== */\n    let FrameCount = parseInt(answer[0] + answer[1] + answer[2], 16)\n    let RecipientID = parseInt(answer[3], 16)\n    let NodeId = parseInt(answer[4], 16) //SenderID\n    let BanID = parseInt(answer[5], 16)\n    let FCS = parseInt(answer[6], 16)\n    //answer[7]~[10]はタイムスタンプ\n    let samplingTiming = parseInt(answer[11], 16)\n    let seqNum = parseInt((answer[12]), 16)\n    let SensorType = parseInt(answer[13], 16)\n    let FrameParity = parseInt(answer[14] + answer[15], 16)\n    let len = 1\n    \n    //let dataArr = answer.slice(15)\n\n    //json構造体の設定\n    msg.Ndata = {\n        FrameCount: FrameCount,//0~2\n        RecipientID: RecipientID,//3\n        NodeId: NodeId,//4\n        BanID: BanID,//5\n        FCS: FCS,//6\n        TimeStamp: timestamp,//7~10\n        samplingTiming: samplingTiming,//11\n        SequenceNum: seqNum,//12\n        SensorType: SensorType,//13\n        FrameParity: FrameParity,//14,15\n        Len: len,\n    }\n\n    //追加・msg.payloadにデータフィールドを設定・データサイズを変更可\n    msg.payload = answer.slice(16, 108)\n    //msg.payload = dataArr\n    msg.hubDate = hubDate\n    msg.receiveDate = now\n\n    //msg.payload = [\n         //answer[9], answer[10], answer[11], answer[12], answer[13], answer[14], answer[15], \n    //     answer[16], answer[17],\n    //     answer[18], answer[19], answer[20], answer[21], answer[22], answer[23], answer[24], answer[25], answer[26], answer[27],\n    //     answer[28], answer[29], answer[30], answer[31], answer[32], answer[33], answer[34], answer[35], answer[36], answer[37],\n    //     answer[38], answer[39], answer[40], answer[41], answer[42], answer[43], answer[44], answer[45], answer[46], answer[47],\n    //     answer[48], answer[49], answer[50], answer[51], answer[52], answer[53], answer[54], answer[55], answer[56], answer[57],\n    //     answer[58], answer[59], answer[60], answer[61], answer[62], answer[63], answer[64], answer[65], answer[66], answer[67],\n    //     answer[68], answer[69], answer[70], answer[71], answer[72], answer[73], answer[74], answer[75], answer[76], answer[77],\n    //     answer[78], answer[79], answer[80], answer[81], answer[82], answer[83], answer[84], answer[85], answer[86], answer[87],\n    //     answer[88], answer[89], answer[90], answer[91], answer[92], answer[93], answer[94], answer[95], answer[96], answer[97],\n    //     answer[98], answer[99], answer[100], answer[101], answer[102], answer[103], answer[104], answer[105], answer[106], answer[107]\n    // ]\n    //console.log(msg.payload);\n\n    return msg;\n\n} else {\n    return null;\n}",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
