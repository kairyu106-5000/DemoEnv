    {
        "id": "ba94fe073d8a95aa",
        "type": "function",
        "z": "a99e786f7afaa3c5",
        "name": "window",
        "func": "// ================ define window function ================\nconst window_function = (name, N) => {\n    let window = []\n    let acf = 0\n    switch (name) {\n        case \"hanning\":\n            for (let i = 0; i < N; i++) {\n                let tmp = (0.5 - 0.5 * Math.cos(2 * Math.PI * i / (N - 1)))\n                window.push(tmp)\n                acf += tmp\n            }\n            break;\n        case \"hamming\":\n            for (let i = 0; i < N; i++) {\n                let tmp = (0.54 - 0.46 * Math.cos(2 * Math.PI * i / (N - 1)))\n                window.push(tmp)\n                acf += tmp\n            }\n            break;\n        case \"blackman\":\n            for (let i = 0; i < N; i++) {\n                let tmp = (0.42 - 0.5 * Math.cos(2 * Math.PI * i / (N - 1)) + 0.08 * Math.cos(4 * Math.PI * i / (N - 1)))\n                window.push(tmp)\n                acf += tmp\n            }\n            break;\n        case \"rectangular\":\n            for (let i = 0; i < N; i++) {\n                window.push(1)\n                acf += 1\n            }\n            break;\n        default:\n            for (let i = 0; i < N; i++) {\n                window.push(1)\n                acf += 1\n            }\n            break;\n    }\n    acf = 1 / (acf / N)\n    return { window: window, acf: acf }\n}\n\n// =====================================================\n\nlet input = msg.payload\n\n// 窓関数の設定\nconst window_name = env.get(\"WINDOW_TYPE\");\nlet N = input.length\nconst {window, acf} = window_function(window_name, N)\n\nlet windowedData = input.map((v, i) => [v[0] * window[i], v[1]])\n\nmsg.payload = {\n    data:windowedData,\n    acf: acf\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 660,
        "y": 180,
        "wires": [
            [
                "027b2023c26a2543"
            ]
        ]
    },
    {
        "id": "6b44c0c1c766c064",
        "type": "function",
        "z": "a99e786f7afaa3c5",
        "name": "convert_complex",
        "func": "let input = msg.payload\nlet complexArr = []\n\nlet prop = env.get(\"PROPERTY\")\nif (!prop) {\n    input.map((r)=>{\n        complexArr.push([r,0]);\n    })\n} else {\n    input.map((r)=>{\n        complexArr.push([r[prop], 0]);\n    })\n}\n\nmsg.payload = complexArr\n\nreturn msg;",
