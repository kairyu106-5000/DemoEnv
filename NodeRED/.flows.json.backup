    {
        "id": "cba6e0cdb7a6cfbf",
        "type": "function",
        "z": "866808d7a9f51b30",
        "name": "batch_peak_detector",
        "func": "let dataArr = msg.payload\n\n// 前後比較するインデックスの配列を作成する(1から開始、後ろから2番目まで)\nlet baseId = Array.from({length: (dataArr.length-2)},(_, i)=> i+1)\nlet peakLoc = baseId.filter((index) =>{\n    return dataArr[index].ecg > dataArr[index - 1].ecg && dataArr[index].ecg > dataArr[index + 1].ecg\n})\nif(peakLoc){\n    peakLoc.map(index=>{\n        msg = {\n            payload: dataArr[index].ecg,\n            timestamp: dataArr[index].timestamp,\n            Ndata: dataArr[index].Ndata,\n            samplingTime: msg.samplingTime\n        }\n        node.send(msg)\n    })\n    node.done()\n}else{\n    return null\n}\n// let peakData = peakLoc.map(index=> dataArr[index])\n\n// for (let i=0, length = peakData.length; i<length;i++){\n//     msg = {\n//         payload: peakData[i].ecg,\n//         timestamp: peakData[i].timestamp,\n//         Ndata: peakData[i].Ndata\n//     }\n//     node.send(msg);\n// }\n\nreturn null;",
