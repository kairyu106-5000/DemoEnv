    {
        "id": "1a0bf43a36cec939",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "calc_RRI_PSD",
        "func": "// ================ define functions ================\nconst expi = (theta) => {\n    return [Math.cos(theta), Math.sin(theta)]\n}\nconst iadd = ([ax, ay], [bx, by]) => {\n    return [ax + bx, ay + by]\n}\nconst isub = ([ax, ay], [bx, by]) => {\n    return [ax - bx, ay - by]\n}\nconst imul = ([ax, ay], [bx, by]) => {\n    return [ax * bx - ay * by, ax * by + ay * bx]\n}\nconst isum = (cs) => {\n    return cs.reduce((s, c) => iadd(s, c), [0, 0])\n}\nconst conj = ([x, y]) => {\n    return [x, -y];\n}\nconst revBit = (k,n0) =>{\n    if (k === 1) return n0;\n    const s1 = ((n0 & 0xaaaaaaaa) >>> 1) | ((n0 & 0x55555555) << 1);\n    if (k === 2) return s1;\n    const s2 = ((s1 & 0xcccccccc) >>> 2) | ((s1 & 0x33333333) << 2);\n    if (k <= 4) return s2 >>> (4 - k);\n    const s3 = ((s2 & 0xf0f0f0f0) >>> 4) | ((s2 & 0x0f0f0f0f) << 4);\n    if (k <= 8) return s3 >>> (8 - k);\n    const s4 = ((s3 & 0xff00ff00) >>> 8) | ((s3 & 0x00ff00ff) << 8);\n    if (k <= 16) return s4 >>> (16 - k);\n    const s5 = ((s4 & 0xffff0000) >>> 16) | ((s4 & 0x0000ffff) << 16);\n    return s5 >>> (32 - k);\n}\n\n/* calc fft by recursive function*/\nconst fftrec = (c, T, N) => {\n    const k = Math.log2(N);\n    const rec = c.map((_, i) => c[revBit(k, i)]);\n    for (let Nh = 1; Nh < N; Nh *= 2) {\n        T /= 2;\n        for (let s = 0; s < N; s += Nh * 2) {\n            for (let i = 0; i < Nh; i++) {\n                const l = rec[s + i], re = imul(rec[s + i + Nh], expi(T * i));\n                [rec[s + i], rec[s + i + Nh]] = [iadd(l, re), isub(l, re)];\n            }\n        }\n    }\n    return rec\n}\n\n/* use recursive fft method */\nconst fft = (f) => {\n    const N = f.length, T = -2 * Math.PI;\n    return fftrec(f, T, N);\n}\nconst ifft = (F) => {\n    const N = F.length, T = 2 * Math.PI;\n    return fftrec(F, T, N).map(([r, i]) => [r / N, i / N]);\n}\n\n/* FFT by Bluestein's algorithm */\nconst fftin = (c, T, N) => {\n    const Nd = N * 2;\n    const bc = c.map((_, n) => expi(T * n * n / Nd));\n    const b = bc.map(conj);\n    const a = c.map((cn, n) => imul(cn, bc[n]));\n\n    const N2 = 1 << (32 - Math.clz32(Nd - 1));\n    const a2 = a.concat(Array(N2 - N).fill([0, 0]));\n    const b2 = b.concat(Array(N2 - Nd + 1).fill([0, 0]), b.slice(1).reverse());\n    const A2 = fft(a2);\n    const B2 = fft(b2);\n    const AB2 = A2.map((A2n, n) => imul(A2n, B2[n]));\n    const ab2 = ifft(AB2);\n    return bc.map((bcn, n) => imul(bcn, ab2[n]));\n}\n\nconst fft1 = (f) => {\n    const N = f.length, T = -2 * Math.PI;\n    return fftin(f, T, N);\n}\nconst ifft1 = (F) => {\n    const N = F.length, T = 2 * Math.PI;\n    return fftin(F, T, N).map(([r, i]) => [r / N, i / N]);\n}\n\nconst calcPowerSpectrum = (f, resolution) => {\n    return f.map((r, index) => [(resolution * index).toPrecision(6), Math.sqrt(r[0] ** 2 + r[1] ** 2)])\n}\n\n// ================================================\n\n/**\n *  横軸分解能\n *  ΔHz = 1/(2^N * Δt) \n *  \n */\n\nlet input = msg.payload\nlet timestamp = msg.timestamp\n// let samplingTime = msg.samplingTime\n// let samplingTime = 500;\nlet samplingTime = 1000;\nconst f_resolution = 1 / (input.length * samplingTime/1000)\n// const f_resolution = 1 / (input.length * 0.2)\n\nlet RRIArr=[]\ninput.map((r)=> {\n    RRIArr.push([r[\"RRI\"], 0]);\n});\n\nconst F_RRI = fft1(RRIArr)\n\nconst PS = calcPowerSpectrum(F_RRI, f_resolution)\n\nlet RRI_PS_obj = {}\n\nPS.map((r)=> RRI_PS_obj[r[0]] = r[1])\n\nlet RRI_PSD = {}\n\nconst offset = 1e-10\n\nPS.map((r) => RRI_PSD[r[0]] = 10 * Math.log10(r[1] / f_resolution + offset))\n\nmsg = {\n    payload:{\n        PS: RRI_PS_obj,\n        PSD: RRI_PSD,\n        F: F_RRI\n    },\n    timestamp: timestamp,\n    Ndata: msg.Ndata\n}\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 300,
        "y": 1300,
        "wires": [
            [
                "379f8fda0d499a05"
            ]
        ]
    },
