    {
        "id": "ecaefe82d238b19f",
        "type": "function",
        "z": "a893cba93cb6f041",
        "name": "calc_PSD(acc)",
        "func": "// ============= define complex function =============\nconst expi = (theta) =>{\n    return [Math.cos(theta), Math.sin(theta)]\n}\nconst iadd = ([ax, ay],[bx, by])=>{\n    return [ax + bx, ay + by]\n}\nconst isub = ([ax, ay], [bx, by]) =>{\n    return [ax - bx, ay - by]\n}\nconst imul = ([ax,ay],[bx,by]) =>{\n    return [ax*bx - ay*by, ax*by + ay*bx]\n}\nconst isum = (cs) =>{\n    return cs.reduce((s,c) => iadd(s,c), [0,0])\n}\n\n// ============= define window function =============\nconst window_function = (name, N) =>{\n    let window = []\n    switch(name){\n        case \"hanning\":\n            for(let i = 0; i < N; i++){\n                window.push((0.5 - 0.5 * Math.cos(2 * Math.PI * i / (N - 1))))\n            }\n            return window\n        case \"hamming\":\n            for (let i = 0; i < N; i++) {\n                window.push((0.54 - 0.46 * Math.cos(2 * Math.PI * i / (N - 1))))\n            }\n            return window\n        case \"blackman\":\n            for (let i = 0; i < N; i++) {\n                window.push((0.42 - 0.5 * Math.cos(2 * Math.PI * i / (N - 1)) + 0.08 * Math.cos(4 * Math.PI * i / (N - 1))))\n            }\n            return window\n        default:\n            for (let i = 0; i < N; i++) {\n                window.push(1)\n            }\n            return window\n    }\n}\n\nconst conv_window = (data,window) =>{\n    let ans = new Array()\n    data.map((v,i) => ans.push([v[0]*window[i], v[1]]))\n    return ans;\n    // switch(name){\n    //     case \"hanning\":\n    //         data.map((v,i) => ans.push([v[0] * (0.5 - 0.5 * Math.cos(2 * Math.PI * i / (N - 1))), v[1]]))\n    //         return ans;\n    //     case \"hamming\":\n    //         data.map((v, i) => ans.push([v[0] * (0.54 - 0.46 * Math.cos(2 * Math.PI * i / (N - 1))), v[1]]))\n    //         return ans;\n    //     case \"blackman\":\n    //         data.map((v, i) => ans.push([v[0] * (0.42 - 0.5 * Math.cos(2 * Math.PI * i / (N - 1)) + 0.08 * Math.cos(4 * Math.PI * i / (N - 1))), v[1]]))\n    //         return ans;\n    //     default:\n    //         return data\n    // }\n}\n\n\n// ============= define FFT function =============\n\n/* calc fft by recursive function*/\nconst fftrec = (c, T, N, s=0, w=1) =>{\n    if(N === 1) return [c[s]];\n    const Nh = N/2, Td = T*2, wd = w*2;\n    const rec = fftrec(c, Td, Nh, s, wd).concat(fftrec(c, Td, Nh, s+w, wd));\n    for(let i=0; i<Nh; i++){\n        const l = rec[i], re= imul(rec[i+Nh],expi(T*i));\n        [rec[i], rec[i+Nh]] = [iadd(l, re), isub(l, re)];\n    }\n    return rec\n}\n\nconst fft0 = (f) =>{\n    const N = f.length, T = -2 * Math.PI / N;\n    return fftrec(f,T,N)\n}\n\nconst ifft0 = (F) =>{\n    const N = F.length, T = 2 * Math.PI / N;\n    return fftrec(F, T, N).map(([r, i])=> [r/N, i/N])\n}\n\nconst calcPowerSpectrum = (f, resolution) =>{\n    // return f.map((r, index) => [(resolution * index).toPrecision(3),Math.sqrt(r[0]**2 + r[1]**2)])\n    let N = f.length\n    return f.map((r, index) => [(resolution * index).toPrecision(3), (Math.sqrt(r[0] ** 2 + r[1] ** 2)) / N*2])\n}\n\n// ================================================\n\n/**\n *  横軸分解能\n *  ΔHz = 1/(2^N * Δt) \n *  \n */\n\nlet input = msg.payload\nlet timestamp = msg.timestamp\nlet samplingTime = msg.samplingTime\n\nconst f_resolution = 1 / (input.length * samplingTime/1000)\n// const f_resolution = 1 / (input.length * 0.2)\n\nconst window_name = env.get(\"WINDOW_FUNCTION\");\nlet N = input.length\nconst window = window_function(window_name, N)\n\nlet accXArr=[], accYArr=[], accZArr=[];\ninput.map((r)=> {\n    accXArr.push([r[\"acc_x\"], 0]);\n    accYArr.push([r[\"acc_y\"], 0]);\n    accZArr.push([r[\"acc_z\"], 0]);\n});\n\nlet accXArr_windowed = conv_window(accXArr, window)\nlet accYArr_windowed = conv_window(accYArr, window)\nlet accZArr_windowed = conv_window(accZArr, window)\n\nconst F_accX = fft0(accXArr_windowed)\nconst F_accY = fft0(accYArr_windowed)\nconst F_accZ = fft0(accZArr_windowed)\n\nlet acc_x_PS = calcPowerSpectrum(F_accX, f_resolution)\nlet acc_y_PS = calcPowerSpectrum(F_accY, f_resolution)\nlet acc_z_PS = calcPowerSpectrum(F_accZ, f_resolution)\n\n// 窓補正\nconst acf = 1/(window.reduce((sum,element)=>sum+element,0)/N)\n\nlet acc_x_PS_obj = {}\nlet acc_y_PS_obj = {}\nlet acc_z_PS_obj = {}\n\n// 窓補正ありの場合\nacc_x_PS.map((r)=> acc_x_PS_obj[r[0]] = r[1]*acf)\nacc_y_PS.map((r) => acc_y_PS_obj[r[0]] = r[1]*acf)\nacc_z_PS.map((r) => acc_z_PS_obj[r[0]] = r[1]*acf)\n\n// 窓補正なしの場合\n// acc_x_PS.map((r) => acc_x_PS_obj[r[0]] = r[1])\n// acc_y_PS.map((r) => acc_y_PS_obj[r[0]] = r[1])\n// acc_z_PS.map((r) => acc_z_PS_obj[r[0]] = r[1])\n\n\nlet acc_x_PSD = {}\nlet acc_y_PSD = {}\nlet acc_z_PSD = {}\n\nconst offset = 1e-10\n\nacc_x_PS.map((r) => acc_x_PSD[r[0]] = 10 * Math.log10(r[1] / f_resolution + offset))\nacc_y_PS.map((r) => acc_y_PSD[r[0]] = 10 * Math.log10(r[1] / f_resolution + offset))\nacc_z_PS.map((r) => acc_z_PSD[r[0]] = 10 * Math.log10(r[1] / f_resolution + offset))\n\nmsg = {\n    payload:{\n        acc_x:{\n            PS: acc_x_PS_obj,\n            PSD: acc_x_PSD,\n            F: F_accX\n        },\n        acc_y:{\n            PS: acc_y_PS_obj,\n            PSD: acc_y_PSD,\n            F: F_accY\n        },\n        acc_z:{\n            PS: acc_z_PS_obj,\n            PSD: acc_z_PSD,\n            F: F_accZ\n        }\n    },\n    timestamp: timestamp,\n    Ndata: msg.Ndata\n}\n\nreturn msg;",
