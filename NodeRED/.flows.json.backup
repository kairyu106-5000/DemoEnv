    {
        "id": "2a5ed04a23ad4a9b",
        "type": "comment",
        "z": "b6720ac1884745ba",
        "name": "fields設定",
        "info": "templateノードを使用して\n以下の構造のpayloadを作成する\n\n```\n{\n    \"field1名\": {{payload.field1のvalue}}\n    \"field2名\": {{payload.field2のvalue}}\n    ...\n\n}\n```\n\n構文や形式はmustacheを指定し、\n出力形式はJSONを指定すること",
        "x": 600,
        "y": 180,
        "wires": []
    },
    {
        "id": "8f6371dea822e8c4",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "prepare_sendData_for_influxdb_old",
        "func": "// console.log(\"[\" + new Date().getTime() + \"]\" + \"start preparing process...\")\n\nmsg.ResultTime = new Date()\n\n// ========== measurement用データ ==========\nlet measurement = msg.measurement\n\n// ========== tag用データ ==========\nconst node_id = msg.Ndata.NodeId\nconst sensor_type = msg.Ndata.SensorType\n// const time = msg.Ndata.TimeStamp\n// const receiveTime = msg.Ndata.receiveDate\n\nconst tag = msg.tag;\n\nlet tagData = {\n    \"NodeId\": String(node_id),\n    \"SensorType\": String(sensor_type),\n}\n\nif(tag){\n    Object.assign(tagData, tag)\n}\n\n// ========== field用データ ==========\nlet fields = msg.payload\n\n// ========== timestamp用データ ==========\nlet timestamp = msg.timestamp\n\n// ========== DB書き込みデータ作成 ==========\nmsg.payload = {\n    // You bucket\n    // Optional (it can be defined in the node credentials settings)\n    bucket: 'node-data',\n\n    // Precision of timestamp\n    // Optional\n    // Can be `ns` (nanoseconds),\n    //        `us` (microseconds),\n    //        `ms` (milliseconds),\n    //        `s` (seconds).\n    // The default is `ns`\n    // Note: if you set the `timestamp` field to `Date.now()`, you have to set the `precision` to `ms`\n    precision: 'ms',\n\n    // Data to send to InfluxDB\n    // Can be an array of objects or only one object\n    data: [\n        {\n            measurement: measurement,\n            tags: tagData,\n            fields: fields,\n            timestamp: timestamp.getTime()\n        },\n\n        // More data can be send here, simply re add an object\n        // { ... },\n    ]\n};\n\n// console.log(\"==========================\")\n// console.log(\"data: \" + tagData.SensorType)\n// console.log(\"resultTime: \" + now.getTime())\n// console.log(\"receiveTime: \" + receiveTime.getTime())\n// console.log(\"result: \" + now.getTime() + \" receive: \" + receiveTime.getTime() + \" timestamp: \" + timestamp.getTime() + \" Type: \" + measurement + \" Len: \" + msg.Ndata.Len)\n// console.log(\"passTime: \" + (now.getTime() - receiveTime.getTime()))\n// console.log(\"diffTime: \" + (receiveTime.getTime() - timestamp.getTime()))\n// console.log(\"send:\" + measurement + \" is complete\")\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1160,
        "y": 1520,
        "wires": [
            [
                "a68ee2194bcc26d7"
            ]
        ]
    },
