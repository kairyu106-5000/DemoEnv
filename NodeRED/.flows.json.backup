    {
        "id": "b99ca6956d5abde6",
        "type": "comment",
        "z": "b6720ac1884745ba",
        "name": "計算ノード",
        "info": "functionノードやサブフローを用いて\n出力結果を得るフェーズ\n\n入出力は以下の形式に従うこと\n\n入力: {\n    msg.payload: String[], // 16進数表記のデータ配列\n    Len: msg.Ndata.Len, // 1回の送信に格納されているデータ数\n    currentDate: msg.currentDate // タイムスタンプに対応した時刻\n}\n\n出力:{\n    msg: {\n        payload: any, // 1つまたは複数のデータ, 複数の場合は識別できるようにデータ名を追加したDict型にする\n        Ndata: msg.Ndata, // ヘッダ情報\n        timestamp: Date, // currentDateを用いてセンサがデータ取得した時刻を算出する\n    }\n}\n",
        "x": 400,
        "y": 200,
        "wires": []
    },
    {
        "id": "e08abc4b1c7daf84",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "GNSS_proc_v01",
        "func": "let input = msg.payload;\nlet tlen = msg.Ndata.Len;\nlet datetime = msg.receiveDate\n// let currentDate = msg.currentDate\nlet hubDate = msg.hubDate\n\n// 入力に値がなければnull、値があればFloatにして返す関数\nconst formatData = (input) =>{\n    let res = !input ? null : parseFloat(input)\n    return res\n}\n\nif (tlen == 0) {\n    return null;\n}\n\nlet text = \"\"\nfor (let i=0, l=input.length;i<l;i++){\n    let str = String.fromCharCode(parseInt(input[i],16))\n    text += str\n}\n\nif(text === \"\") {return null}\n\nlet dataArr = text.split(\",\")\n\nlet utcPosFix = dataArr[1]\nlet latDegree = parseFloat(dataArr[2])\nlet latId \nif (dataArr[3] == \"S\"){\n    latId = -1\n}else{\n    latId = 1\n}\n\nlet lngDegree = parseFloat(dataArr[4])\nlet lngId\nif(dataArr[5] == \"W\"){\n    lngId = -1\n}else{\n    lngId = 1\n} \n\nlet quality = formatData(dataArr[6])\nlet numSV = formatData(dataArr[7])\nlet HDOP = formatData(dataArr[8])\nlet alt = formatData(dataArr[9])\nlet altUnit = dataArr[10]\nlet geoid = formatData(dataArr[11])\nlet geoidUnit = dataArr[12]\nlet diffAge = formatData(dataArr[13])\nlet stationId = dataArr[14].split(\"*\")[0]\n\nlet lat = isNaN(latDegree) ? null : latId * latDegree / 100 // ddmm.mmmmをdd.mmmmmmmに直すため\nlet lng = isNaN(lngDegree) ? null : latId * lngDegree / 100\n\nmsg = {\n    payload: {\n        lat: lat,\n        lng: lng,\n        alt: alt,\n        geoid: geoid,\n        quality: quality,\n        numSV: numSV,\n        HDOP: HDOP,\n        // diffAge: diffAge,\n        // stationId: stationId\n    },\n    Ndata: msg.Ndata,\n    // timestamp: currentDate\n    timestamp: hubDate\n}\n\n// payload内にnullがあるかどうかチェックする関数\nconst hasNull = (obj) =>{\n    for(let key in obj){\n        if(obj[key] === null){\n            return true\n        }\n    }\n    return false\n}\n\n// nullがない時だけ送信する\nif(!hasNull(msg.payload)){\n    return msg\n}else{\n    return null\n}\n",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1010,
        "y": 1140,
        "wires": [
            []
        ]
    },
    {
        "id": "f2dd25301583278f",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "GNSS_debug",
        "func": "// let input = msg.payload;\nlet input = [\"24\", \"47\", \"4e\", \"47\", \"47\", \"41\", \"2c\", \"30\", \"34\", \"32\", \"34\", \"33\", \"33\", \"2e\", \"30\", \"30\", \"2c\", \"33\", \"34\", \"32\", \"36\", \"2e\", \"34\", \"31\", \"36\", \"37\", \"36\", \"2c\", \"4e\", \"2c\", \"31\", \"33\", \"32\", \"32\", \"34\", \"2e\", \"39\", \"31\", \"32\", \"39\", \"33\", \"2c\", \"45\", \"2c\", \"31\", \"2c\", \"30\", \"34\", \"2c\", \"33\", \"2e\", \"34\", \"38\", \"2c\", \"31\", \"38\", \"38\", \"2e\", \"36\", \"2c\", \"4d\", \"2c\", \"33\", \"30\", \"2e\", \"31\", \"2c\", \"4d\", \"2c\", \"2c\", \"2a\", \"34\", \"39\", \"0d\", \"0a\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"\"]\n\nlet input2 = [\n    \"02\", \"03\", \"00\", \"27\", \"00\", \"00\", \"a1\", \"3f\", \"01\", \"24\", \"47\", \"4e\", \"47\", \"47\", \"41\", \"2c\", \"2c\", \"2c\", \"2c\", \"2c\", \"2c\", \"30\", \"2c\", \"30\", \"30\", \"2c\", \"39\", \"39\", \"2e\", \"39\", \"39\", \"2c\", \"2c\", \"2c\", \"2c\", \"2c\", \"2c\", \"2a\", \"35\", \"36\", \"0d\", \"0a\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"00\", \"\"\n]\n\n\nmsg.Ndata = {\n    NodeName: 3,\n    SensorType: 3,\n    SequenceNum: 1,\n    TimeStamp: 10578,\n    Len: 1,\n}\n\nlet tlen = msg.Ndata.Len;\n// let datetime = msg.receiveDate\nlet currentDate = new Date()\n\n// 入力に応じて空文字か数値を返す\nconst formatData = (input) => {\n    let res = !input ? null : parseFloat(input)\n    return res\n}\n\n// if (tlen == 0) {\n//     return null;\n// }\n\nlet text = \"\"\nfor (let i = 0, l = input.length; i < l; i++) {\n    let str = String.fromCharCode(parseInt(input[i], 16))\n    text += str\n}\n\nlet dataArr = text.split(\",\")\n\nlet utcPosFix = dataArr[1]\n// console.log(utcPosFix)\nlet latDegree = parseFloat(dataArr[2])\n\nlet latId\nif (dataArr[3] == \"S\") {\n    latId = -1\n} else {\n    latId = 1\n}\n\nlet lngDegree = parseFloat(dataArr[4])\n\nlet lngId\nif (dataArr[5] == \"W\") {\n    lngId = -1\n} else {\n    lngId = 1\n}\n\nlet quality = formatData(dataArr[6])\nlet numSV = formatData(dataArr[7])\nlet HDOP = formatData(dataArr[8])\nlet alt = formatData(dataArr[9])\nlet altUnit = dataArr[10]\nlet geoid = formatData(dataArr[11])\nlet geoidUnit = dataArr[12]\nlet diffAge = formatData(dataArr[13])\nlet stationId = dataArr[14].split(\"*\")[0]\n\nlet lat = isNaN(latDegree) ? null : latId * latDegree\nlet lng = isNaN(lngDegree) ? null : latId * lngDegree\n\nmsg = {\n    payload: {\n        lat: lat / 100,\n        lng: lng / 100,\n        alt: alt,\n        geoid: geoid,\n        quality: quality,\n        numSV: numSV,\n        HDOP: HDOP,\n        // diffAge: diffAge,\n        // stationId: stationId\n    },\n    Ndata: msg.Ndata,\n    timestamp: currentDate\n}\n\nconst hasNull = (obj) => {\n    for (let key in obj) {\n        if (obj[key] === null) {\n            return true;\n        }\n    }\n    return false;\n}\n// console.log(msg.payload)\n// if (!hasNull(msg.payload)) {\n//     return msg\n// }\n// else {\n//     // console.log(\"null exist\")\n//     return null\n// }\n\nreturn msg;",
