    {
        "id": "063b42f07ee4fd94",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "peak_detection",
        "func": "/**\n *  直前のデータが単調増加していた場合(isIncr=True)かつ\n *  今回のデータが単調減少していた場合、直前のデータがピーク値となる\n *  直前のデータの増減、値、時刻を監視し、ピーク値を検出した場合に、\n *  そのピーク値の情報を次のノードに送信する\n *  \n * \n */\n\nlet input = msg.payload.ecg\nlet time = msg.timestamp\nlet Ndata = msg.Ndata\n\nconst setContext = (data, time, Ndata, isIncr) => {\n    context.set(\"preData\", data)\n    context.set(\"preTime\", time)\n    context.set(\"isIncr\", isIncr)\n    context.set(\"Ndata\", Ndata)\n}\n\nlet isIncr = context.get(\"isIncr\");\nlet preData = context.get(\"preData\");\nlet preTime = context.get(\"preTime\")\n\nif(preData == undefined || preTime === undefined || isIncr === undefined){\n    setContext(input, time, Ndata, isIncr=false)\n    return null\n}\n\n// 直前が単調増加の場合\nif(isIncr){\n    // 今回単調増加の場合\n    if (input >= preData) {\n        setContext(input, time, Ndata, isIncr = true)\n        return null\n    }\n    // 今回単調減少の場合\n    else if (input < preData){\n        msg = {\n            payload: preData,\n            timestamp: preTime,\n            Ndata: Ndata\n        }\n        setContext(input, time, Ndata, isIncr=false)\n        return msg\n    }\n} \n// 直前が単調減少の場合\nelse {\n    // 今回単調増加の場合\n    if (input >= preData) {\n        setContext(input, time, Ndata, isIncr = true)\n        return null\n    } \n    // 今回単調減少の場合\n    else if (input < preData) {\n        setContext(input, time, Ndata, isIncr = false)\n        return null\n    }\n}\n",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 800,
        "y": 1460,
        "wires": [
            []
        ]
    },
