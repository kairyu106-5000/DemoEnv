    {
        "id": "9ea1a8f1f319a729",
        "type": "template",
        "z": "b6720ac1884745ba",
        "name": "GNSS",
        "field": "payload",
        "fieldType": "msg",
        "format": "handlebars",
        "syntax": "mustache",
        "template": "{\n    \"latitude\": {{{payload.lat}}},\n    \"longitude\": {{{payload.lng}}},\n    \"altitude\": {{{payload.alt}}},\n    \"geoid\": {{{payload.geoid}}},\n    \"HDOP\": {{{payload.HDOP}}}\n}",
        "output": "json",
        "x": 590,
        "y": 320,
        "wires": [
            [
                "02ef87676746077c"
            ]
        ]
    },
    {
        "id": "ae80c93a2f48854c",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "GNSS_proc_prototype",
        "func": "let input = msg.payload;\nlet tlen = msg.Ndata.Len;\nlet datetime = msg.receiveDate\nlet currentDate = msg.currentDate\n\nif (tlen == 0) {\n    return null;\n}\n\n/*\nデータの形式\ninputData:{\n    latDegree: data[0],\n    latMinute: data[1] + data[2] + data[3] + data[4],\n    latId: data[5],\n    lngDegree: data[6],\n    lngMinute: data[7] + data[8] + data[9] + data[10],\n    lngId: data[11],\n    quality: data[12],\n    numSV: data[13],\n    HDOP: data[14],\n    alt: data[15] + data[16] + data[17] + data[18],\n    geoid: data[19] + data[20] + data[21] + data[22],\n    diffAge: data[23], \n    stationId: data[24]\n}\n*/\n\nlet latDegree = parseInt(String(input[0]), 16)\nlet latMinute = parseInt(String(input[1]) + String(input[2]) + String(input[3]) + String(input[4]), 16)\nlatMinute = latMinute / (10 ** latMinute.toString().length)\nlet latId = !input[5] ? 1 : -1\nlet lat = latId * (latDegree + latMinute)\n\nlet lngDegree = parseInt(String(input[6]), 16)\nlet lngMinute = parseInt(String(input[7]) + String(input[8]) + String(input[9]) + String(input[10]), 16)\nlngMinute = lngMinute / (10 ** lngMinute.toString().length)\nlet lngId = !input[11] ? 1 : -1\nlet lng = lngId * (lngDegree + lngMinute)\n\nlet quality = input[12]\nlet numSV = input[13]\n\nlet HDOP = input[14]\n\nlet alt = input[15] + input[16] + input[17] + input[18]\nlet geoid = input[19] + input[20] + input[21] + input[22]\n\nlet diffAge = input[23]\nlet stationId = input[24]\n\nmsg ={\n    payload: {\n        lat: lat,\n        lng: lng,\n        alt: alt,\n        geoid: geoid,\n        quality: quality,\n        numSV: numSV,\n        HDOP: HDOP,\n        diffAge: diffAge,\n        stationId: stationId\n    },\n    Ndata: msg.Ndata,\n    timestamp: currentDate\n}\n\nreturn msg;\n",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 820,
        "y": 1380,
        "wires": [
            []
        ]
    },
