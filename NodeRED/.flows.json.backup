    {
        "id": "c35746fceee79177",
        "type": "function",
        "z": "866808d7a9f51b30",
        "name": "parse_ECG_data",
        "func": "// [TODO] センサデータのタイムスタンプとHubのタイムスタンプが乖離していた場合のエラー処理を追加する\n\nlet input = msg.payload;\nlet tlen = msg.Ndata.Len;\nlet hubDate = msg.hubDate\n\nconst BUFFER_SIZE = 3;\nconst samplingTime = 80; // ms\n\nif (tlen == 0) {\n    return null;\n}\n\n// ====== タイムスタンプ算出用 =======\nconst contextName = {\n    startDate: \"$parent.startDate_\" + msg.port,\n    startTime: \"$parent.startTime_\" + msg.port,\n}\n\nconst getCurrentDate = (timeStamp) => {\n    let startDate = flow.get(contextName.startDate)\n    let startTime = flow.get(contextName.startTime)\n    let diffTime = timeStamp - startTime\n    let currentDate = new Date(startDate + diffTime)\n    return currentDate\n}\n// ===================================\n\nlet timeValue = parseInt(input[0] + input[1] + input[2] + input[3], 16)\nlet headDate = getCurrentDate(timeValue)\n\nlet ecgBuffer = input.slice(4)\nlet buffer = new Array()\n// lenのサイズに従ってBuffer配列を作成する\nfor (let cnt = 0; cnt < tlen; cnt++) {\n    buffer[cnt] = new Array()\n    for (let i = 0; i < BUFFER_SIZE; i++) {\n        buffer[cnt].push(ecgBuffer[i + BUFFER_SIZE * cnt])\n    }\n}\n\nlet measurementTime\nfor (let cnt = 0; cnt< tlen; cnt++) {\n    let ecgValue = parseInt(buffer[cnt][0] + buffer[cnt][1] + buffer[cnt][2],16)\n    if (ecgValue & 0x800000) ecgValue |= ~0xffffff; // 24bit\n\n    measurementTime = new Date(headDate.getTime() + (samplingTime * cnt))\n    msg = {\n        Ndata: msg.Ndata,\n        payload: {\n            ecg: ecgValue,\n            Ndata: msg.Ndata,\n            timestamp: measurementTime\n        },\n        timestamp: measurementTime,\n        samplingTime: samplingTime,\n    }\n    node.send(msg);\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 190,
        "y": 80,
        "wires": [
            []
        ]
    },
    {
        "id": "4364bab5514a934a",
        "type": "function",
        "z": "866808d7a9f51b30",
        "name": "calc_HeartRate",
        "func": "let currentDate = msg.timestamp\n\nlet preDate = context.get(\"preDate\")\n\nif(!preDate){\n    context.set(\"preDate\",currentDate)\n    return null\n}\n\nlet RRI = currentDate.getTime() - preDate.getTime()\n\nlet BPM = 1000*60 / RRI\nBPM = Math.trunc(BPM)\n// node.log(\"RRI= \" + RRI + \" ms\")\n// node.log(\"BPM= \" + BPM)\n\nmsg.payload = {\n    HR: BPM,\n    RRI: RRI,\n}\ncontext.set(\"preDate\", currentDate)\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
