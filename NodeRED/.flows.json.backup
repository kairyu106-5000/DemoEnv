    {
        "id": "c6688c4925abb646",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "set_calib",
        "func": "//let calibData = msg.calib\nlet input = msg.payload;\n\nlet calibArr = input.split(\" \")\n\nvar i2cRxBuffer = calibArr.map(str => parseInt(str, 16));\n\nvar dig_T1 = (i2cRxBuffer[1] << 8) | i2cRxBuffer[0];\nvar dig_T2 = (i2cRxBuffer[3] << 8) | i2cRxBuffer[2];\nvar dig_T3 = (i2cRxBuffer[5] << 8) | i2cRxBuffer[4];\nvar dig_P1 = (i2cRxBuffer[7] << 8) | i2cRxBuffer[6];\nvar dig_P2 = (i2cRxBuffer[9] << 8) | i2cRxBuffer[8];\nvar dig_P3 = (i2cRxBuffer[11] << 8) | i2cRxBuffer[10];\nvar dig_P4 = (i2cRxBuffer[13] << 8) | i2cRxBuffer[12];\nvar dig_P5 = (i2cRxBuffer[15] << 8) | i2cRxBuffer[14];\nvar dig_P6 = (i2cRxBuffer[17] << 8) | i2cRxBuffer[16];\nvar dig_P7 = (i2cRxBuffer[19] << 8) | i2cRxBuffer[18];\nvar dig_P8 = (i2cRxBuffer[21] << 8) | i2cRxBuffer[20];\nvar dig_P9 = (i2cRxBuffer[23] << 8) | i2cRxBuffer[22];\nvar dig_H1 = (i2cRxBuffer[24]);\nvar dig_H2 = (i2cRxBuffer[26] << 8) | i2cRxBuffer[25];\nvar dig_H3 = (i2cRxBuffer[27]);\nvar dig_H4 = (i2cRxBuffer[28] << 4) | (0x0F & i2cRxBuffer[29]);\nvar dig_H5 = (i2cRxBuffer[30] << 4) | ((i2cRxBuffer[29] >> 4) & 0x0F);\nvar dig_H6 = (i2cRxBuffer[31]);\n\nmsg.calib = {\n    \"dig_T1\": dig_T1,\n    \"dig_T2\": dig_T2,\n    \"dig_T3\": dig_T3,\n    \"dig_P1\": dig_P1,\n    \"dig_P2\": dig_P2,\n    \"dig_P3\": dig_P3,\n    \"dig_P4\": dig_P4,\n    \"dig_P5\": dig_P5,\n    \"dig_P6\": dig_P6,\n    \"dig_P7\": dig_P7,\n    \"dig_P8\": dig_P8,\n    \"dig_P9\": dig_P9,\n    \"dig_H1\": dig_H1,\n    \"dig_H2\": dig_H2,\n    \"dig_H3\": dig_H3,\n    \"dig_H4\": dig_H4,\n    \"dig_H5\": dig_H5,\n    \"dig_H6\": dig_H6,\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 840,
        "y": 900,
        "wires": [
            [
                "7a2858c30b87631a"
            ]
        ]
    },
    {
        "id": "7a2858c30b87631a",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "separate_Temp",
        "func": "let input = msg.payload;\nlet tlen = msg.Ndata.Len;\nconst samplingTime = 1000\nconst BUFFER_SIZE = 11\n\ntlen = 1;\n\nif (tlen == 0) {\n    return null;\n}\n\nlet datetime = msg.receiveDate\n\nlet buffer = []\n// lenのサイズに従ってBuffer配列を作成する\nfor (let cnt = 0; cnt < tlen; cnt++){\n    buffer[cnt] = new Array(BUFFER_SIZE)\n    for (let i = 0; i < BUFFER_SIZE; i++){\n        buffer[cnt][i] = input[i + BUFFER_SIZE*cnt]\n        buffer[cnt][i] = parseInt(buffer[cnt][i],16)\n    }\n}\n\n// Buffer配列をTemp, press, hum, timestampに分ける\nfor (let cnt = 0; cnt < tlen; cnt++){\n    let dataTime = new Date(datetime.getTime() - (samplingTime * (tlen - cnt - 1)))\n    dataTime = dataTime.getTime();\n\n    // let tempValue = (parseInt(buffer[cnt][2],16)<<16&0xf0) + (parseInt(buffer[cnt][1],16)<<8) + parseInt(buffer[cnt][0], 16)\n    // let pressValue = (parseInt(buffer[cnt][4], 16)<<12) + (parseInt(buffer[cnt][3], 16)<<4) + (parseInt(buffer[cnt][2],16)&0x0f)\n    // let humValue = (parseInt(buffer[cnt][6], 16)<<8) + parseInt(buffer[cnt][5], 16)\n    // let timeValue = parseInt((buffer[cnt][7] + buffer[cnt][8] + buffer[cnt][9] + buffer[cnt][10]),16)\n\n    let tempValue = ((buffer[cnt][2]<<16&0xf0)) | ((buffer[cnt][1])<<8) | (buffer[cnt][0])\n    let pressValue = (buffer[cnt][4] << 12) | ((buffer[cnt][3]) << 4) | (0x0f&(buffer[cnt][2]))\n    let humValue = ((buffer[cnt][6])<<8) | (buffer[cnt][5])\n    let timeValue = (buffer[cnt][7]<<24 | buffer[cnt][8]<<16 | buffer[cnt][9]<<8 | buffer[cnt][10])\n\n    let tempMsg = {\n        Ndata: msg.Ndata,\n        calib: msg.calib,\n        payload: tempValue,\n        timestamp: dataTime,\n        nodeTime: timeValue\n    };\n    let humMsg = {\n        Ndata: msg.Ndata,\n        calib: msg.calib,\n        payload: humValue,\n        timestamp: dataTime,\n        nodeTime: timeValue\n    };\n    let pressMsg = {\n        Ndata: msg.Ndata,\n        calib: msg.calib,\n        payload: pressValue,\n        timestamp: dataTime,\n        nodeTime: timeValue\n    };\n    node.send([tempMsg, humMsg, pressMsg]);\n}\n\nreturn null;\n",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "// ここに記述したコードは、ノードをデプロイした時に\n// 一度だけ実行されます。\n\nvar calibArr = [\n    \"e0\",\"6e\",\"53\",\"69\",\"32\",\n    \"00\",\"a7\",\"8f\",\"29\",\"d7\",\n    \"d0\",\"0b\",\"13\",\"1d\",\"64\",\n    \"00\",\"f9\",\"ff\",\"ac\",\"26\",\n    \"0a\",\"d8\",\"bd\",\"10\",\"4b\",\n    \"6b\",\"01\",\"00\",\"13\",\"2c\",\n    \"03\",\"1e\"\n]\n\nvar i2cRxBuffer = calibArr.map(str => parseInt(str, 16));\n\nvar dig_T1 = (i2cRxBuffer[1] << 8) | i2cRxBuffer[0];\nvar dig_T2 = (i2cRxBuffer[3] << 8) | i2cRxBuffer[2];\nvar dig_T3 = (i2cRxBuffer[5] << 8) | i2cRxBuffer[4];\nvar dig_P1 = (i2cRxBuffer[7] << 8) | i2cRxBuffer[6];\nvar dig_P2 = (i2cRxBuffer[9] << 8) | i2cRxBuffer[8];\nvar dig_P3 = (i2cRxBuffer[11] << 8) | i2cRxBuffer[10];\nvar dig_P4 = (i2cRxBuffer[13] << 8) | i2cRxBuffer[12];\nvar dig_P5 = (i2cRxBuffer[15] << 8) | i2cRxBuffer[14];\nvar dig_P6 = (i2cRxBuffer[17] << 8) | i2cRxBuffer[16];\nvar dig_P7 = (i2cRxBuffer[19] << 8) | i2cRxBuffer[18];\nvar dig_P8 = (i2cRxBuffer[21] << 8) | i2cRxBuffer[20];\nvar dig_P9 = (i2cRxBuffer[23] << 8) | i2cRxBuffer[22];\nvar dig_H1 = (i2cRxBuffer[24]);\nvar dig_H2 = (i2cRxBuffer[26] << 8) | i2cRxBuffer[25];\nvar dig_H3 = (i2cRxBuffer[27]);\nvar dig_H4 = (i2cRxBuffer[28] << 4) | (0x0F & i2cRxBuffer[29]);\nvar dig_H5 = (i2cRxBuffer[30] << 4) | ((i2cRxBuffer[29] >> 4) & 0x0F);\nvar dig_H6 = (i2cRxBuffer[31]);\n\n// この下にflow setで値を格納する\nflow.set(\"dig_T1\", dig_T1);\nflow.set(\"dig_T2\", dig_T2);\nflow.set(\"dig_T3\", dig_T3);\nflow.set(\"dig_H1\", dig_H1);\nflow.set(\"dig_H2\", dig_H2);\nflow.set(\"dig_H3\", dig_H3);\nflow.set(\"dig_H4\", dig_H4);\nflow.set(\"dig_H5\", dig_H5);\nflow.set(\"dig_H6\", dig_H6);\nflow.set(\"dig_P1\", dig_P1);\nflow.set(\"dig_P2\", dig_P2);\nflow.set(\"dig_P3\", dig_P3);\nflow.set(\"dig_P4\", dig_P4);\nflow.set(\"dig_P5\", dig_P5);\nflow.set(\"dig_P6\", dig_P6);\nflow.set(\"dig_P7\", dig_P7);\nflow.set(\"dig_P8\", dig_P8);\nflow.set(\"dig_P9\", dig_P9);",
        "finalize": "",
        "libs": [],
        "x": 880,
        "y": 940,
        "wires": [
            [
                "467f0d22823b1ee3"
            ],
            [],
            []
        ]
    },
    {
        "id": "467f0d22823b1ee3",
        "type": "template",
        "z": "b6720ac1884745ba",
        "name": "temperature",
        "field": "payload",
        "fieldType": "msg",
        "format": "handlebars",
        "syntax": "mustache",
        "template": "{\n    \"temperature\": {{payload}} \n}",
        "output": "json",
        "x": 910,
        "y": 980,
        "wires": [
            [
                "501272ef03543d66"
            ]
        ]
    },
    {
        "id": "501272ef03543d66",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "calc_Temp",
        "func": "let adc_T = msg.payload.temperature\n\n// ----- calibration setting -----\n// const dig_T1 = parseInt(flow.get(\"dig_T1\"), 16)\n// const dig_T2 = parseInt(flow.get(\"dig_T2\"),16)\n// const dig_T3 = parseInt(flow.get(\"dig_T3\"), 16)\n\nconst dig_T1 = msg.calib.dig_T1\nconst dig_T2 = msg.calib.dig_T2\nconst dig_T3 = msg.calib.dig_T3\n\n// global value \nlet var1 = ((((adc_T >> 3) - (dig_T1 << 1))) * (dig_T2)) >> 11;\nlet var2 = (((((adc_T >> 4) - (dig_T1)) * ((adc_T >> 4) - (dig_T1))) >> 12) * (dig_T3)) >> 14;\n\nconst t_fine = var1 + var2\n\n// calc Temperature\nlet temp_cal = (t_fine * 5 + 128) >> 8;\n\nconst temp = temp_cal / 100.0\n\nmsg.payload = temp\n\nconst tfineMsg = {\n    payload: {\n        t_fine: t_fine\n    }\n}\n\nnode.send([msg, tfineMsg]);\n\nreturn null;\n",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 950,
        "y": 1020,
        "wires": [
            [],
            []
        ]
    },
    {
        "id": "d12c280f3021f5b7",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "function 2",
        "func": "var token = \"k6c9S85Nl9wLKqnZnSEETRgpiH42LrN1BdWWZl4hZxc\";\n\nmsg.headers = {\n    \"Content-Type\": \"application/x-www-form-urlencoded\",\n    \"Authorization\": `Bearer ${token}`\n};\nmsg.method = \"POST\";\nmsg.url = \"https://notify-api.line.me/api/notify\";\n\nmsg.payload = {\n    message: msg.payload\n    //message : msg.Ndata.SensorType\n    //message : msg.timestamp\n}\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 860,
        "y": 840,
