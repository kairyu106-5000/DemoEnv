            ]
        ]
    },
    {
        "id": "41ecf268f5a2dc90",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "Temp_proc",
        "func": "let input = msg.payload;\n//node.log(input)\nconst tlen = msg.Ndata.Len;//1\nconst hubDate = msg.hubDate\n// const samplingTime = 40\nconst BUFFER_SIZE = 11\n\n// ====== タイムスタンプ算出用 =======\nconst contextName = {\n    startDate: \"startDate_\" + msg.port,\n    startTime: \"startTime_\" + msg.port,\n    preTime: \"preTime_\" + msg.port,\n}\n\nconst getCurrentDate = (timeStamp) => {\n    const startDate = flow.get(contextName.startDate)\n    const startTime = flow.get(contextName.startTime)\n    let diffTime = timeStamp - startTime\n    let currentDate = new Date(startDate + diffTime)\n    return currentDate\n}\n\n// ===================================\n\nif (tlen == 0) {\n    return null;\n}\n\nlet buffer = []\n// lenのサイズに従ってBuffer配列を作成する\nfor (let cnt = 0; cnt < tlen; cnt++) {\n    buffer[cnt] = new Array()\n    for (let i = 0; i < BUFFER_SIZE; i++) {\n        buffer[cnt].push(input[i + BUFFER_SIZE * cnt])\n    }\n}\n\nconst startDate = flow.get(contextName.startDate)\nconst startTime = flow.get(contextName.startTime)\n\nif ((!startDate) || (!startTime)) {\n    node.warn(\"cannot get context!\");\n    return null\n}\n\n// Buffer配列をTemp, press, hum, timestampに分ける\nlet measurementTime\nfor (let cnt = 0; cnt < tlen; cnt++) {\n    let tempBuf = buffer[cnt][0] + buffer[cnt][1] + ((parseInt(buffer[cnt][2],16)&0xf0)>>4).toString(16)\n    let pressBuf = (parseInt(buffer[cnt][2],16)&0x0f).toString(16) + buffer[cnt][3] + buffer[cnt][4]\n    let humBuf = buffer[cnt][5] + buffer[cnt][6]\n    let timeBuf = buffer[cnt][7] + buffer[cnt][8] + buffer[cnt][9] + buffer[cnt][10]\n\n    let tempValue = parseInt(tempBuf,16) / 100\n    let pressValue = parseInt(pressBuf, 16) /100\n    let humValue = parseInt(humBuf, 16) / 1024\n    let timeValue = parseInt(timeBuf, 16)\n\n    measurementTime = getCurrentDate(timeValue)\n    //node.log(tempValue)\n    //node.log(\"温度\")\n    msg = {\n        Ndata: msg.Ndata,\n        payload: {\n            \"temperature\": tempValue,\n            \"humidity\": humValue,\n            \"pressure\": pressValue\n        },\n        timestamp: measurementTime\n    }\n    if (tempValue >0 && tempValue <100){\n        node.send(msg);\n    }\n    \n}\n\nreturn null;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 240,
        "wires": [
            [
                "fe8a86278f184804",
                "e10503c65d8fbdd3",
                "d9f002278481a023"
            ]
        ]
    },
