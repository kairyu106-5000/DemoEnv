    {
        "id": "fe8a86278f184804",
        "type": "template",
        "z": "b6720ac1884745ba",
        "name": "ENV",
        "field": "payload",
        "fieldType": "msg",
        "format": "handlebars",
        "syntax": "mustache",
        "template": "{\n    \"Temperature\": {{payload.temperature}},\n    \"Humidity\": {{payload.humidity}},\n    \"Pressure\": {{payload.pressure}}\n}",
        "output": "json",
