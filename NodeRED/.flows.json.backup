    {
        "id": "ef1253d220e6ab36",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "ecg_test_emitter",
        "func": "const contextName ={\n    count: \"TestEcgCount\"\n}\n\nconst ecgData = [\n    0.980858445, 0.359048724, 0.060324825, 0.009280742, \n    0.092807427, 0.185614854, 0.201276109, 0.220417634, \n    0.220997676, 0.217517406, 0.225638047, 0.225638047, \n    0.231438518, 0.230278417, 0.22737819, 0.236078888,\n    0.236078888, 0.232598603, 0.239559159, 0.255220413, \n    0.27262181, 0.287703007, 0.298143864, 0.320185602, \n    0.339327157, 0.357888639, 0.372969836, 0.378190249, \n    0.393851519, 0.386310905, 0.384570777, 0.38515082, \n    0.36716938, 0.350928068, 0.332366586, 0.308004647, \n    0.289443165, 0.272041768, 0.255220413, 0.247099772, \n    0.239559159, 0.243619487, 0.235498846, 0.232598603,\n    0.231438518, 0.236078888, 0.236658931, 0.23317866, \n    0.236658931, 0.241299301, 0.240719259, 0.247099772, \n    0.247099772, 0.252900243, 0.243039444, 0.248259857,\n    0.259860784, 0.256380498, 0.25, 0.243619487, \n    0.247679815, 0.249419957, 0.327726215, 0.313225061, \n    0.317865431, 0.328306258, 0.369489551, 0.395011604, \n    0.408352673, 0.343387485, 0.332366586, 0.279002309, \n    0.248259857, 0.224477962, 0.211716935, 0.203016236, \n    0.204756379, 0.198375866, 0.193735495, 0.195475638, \n    0.190835267, 0.203016236, 0.198375866, 0.275522053, \n    0.396171689, 0.495359629, 0.759860814\n]\n\nlet time = new Date(msg.payload)\n\nlet Ndata = {\n    NodeId: 2,\n    SensorType: 5,\n    SequenceNum: 1,\n    TimeStamp: 1000,\n    Len: 1,\n}\n\nlet count = context.get(contextName.count)\nif (!count){\n    count = 0;\n    context.set(contextName.count, 0);\n}\n\n// msg.payload = ecgData[count%87]\n\nmsg = {\n    payload: {\n        ecg: ecgData[count%ecgData.length],\n        timestamp: time,\n        Ndata: Ndata\n    },\n    Ndata: Ndata,\n    timestamp: time\n}\n\ncontext.set(contextName.count,count+1)\n\nreturn msg;",
