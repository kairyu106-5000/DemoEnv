    {
        "id": "21ce22fc77566abd",
        "type": "function",
        "z": "007a7381dc88608d",
        "name": "set_calib",
        "func": "let calibData = msg.calib\n\nlet calibArr = calibData.split(\" \")\n\nvar i2cRxBuffer = calibArr.map(str => parseInt(str, 16));\n\nvar dig_T1 = (i2cRxBuffer[1] << 8) | i2cRxBuffer[0];\nvar dig_T2 = (i2cRxBuffer[3] << 8) | i2cRxBuffer[2];\nvar dig_T3 = (i2cRxBuffer[5] << 8) | i2cRxBuffer[4];\nvar dig_P1 = (i2cRxBuffer[7] << 8) | i2cRxBuffer[6];\nvar dig_P2 = (i2cRxBuffer[9] << 8) | i2cRxBuffer[8];\nvar dig_P3 = (i2cRxBuffer[11] << 8) | i2cRxBuffer[10];\nvar dig_P4 = (i2cRxBuffer[13] << 8) | i2cRxBuffer[12];\nvar dig_P5 = (i2cRxBuffer[15] << 8) | i2cRxBuffer[14];\nvar dig_P6 = (i2cRxBuffer[17] << 8) | i2cRxBuffer[16];\nvar dig_P7 = (i2cRxBuffer[19] << 8) | i2cRxBuffer[18];\nvar dig_P8 = (i2cRxBuffer[21] << 8) | i2cRxBuffer[20];\nvar dig_P9 = (i2cRxBuffer[23] << 8) | i2cRxBuffer[22];\nvar dig_H1 = (i2cRxBuffer[24]);\nvar dig_H2 = (i2cRxBuffer[26] << 8) | i2cRxBuffer[25];\nvar dig_H3 = (i2cRxBuffer[27]);\nvar dig_H4 = (i2cRxBuffer[28] << 4) | (0x0F & i2cRxBuffer[29]);\nvar dig_H5 = (i2cRxBuffer[30] << 4) | ((i2cRxBuffer[29] >> 4) & 0x0F);\nvar dig_H6 = (i2cRxBuffer[31]);\n\nmsg.calib = {\n    \"dig_T1\": dig_T1,\n    \"dig_T2\": dig_T2,\n    \"dig_T3\": dig_T3,\n    \"dig_P1\": dig_P1,\n    \"dig_P2\": dig_P2,\n    \"dig_P3\": dig_P3,\n    \"dig_P4\": dig_P4,\n    \"dig_P5\": dig_P5,\n    \"dig_P6\": dig_P6,\n    \"dig_P7\": dig_P7,\n    \"dig_P8\": dig_P8,\n    \"dig_P9\": dig_P9,\n    \"dig_H1\": dig_H1,\n    \"dig_H2\": dig_H2,\n    \"dig_H3\": dig_H3,\n    \"dig_H4\": dig_H4,\n    \"dig_H5\": dig_H5,\n    \"dig_H6\": dig_H6,\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 260,
        "wires": [
            [
                "d4ebc531a47d74b5"
            ]
        ]
    },
    {
        "id": "48d63b321381de68",
        "type": "function",
        "z": "51941ff1083ce014",
        "name": "Separate_RED_IR",
        "func": "let input = msg.payload;\nlet tlen = msg.Ndata.Len;\nlet currentDate = msg.currentDate\n\nconst samplingTime = 150\n\nif (tlen == 0){\n    return null;\n}\n\nconst bitSize = 4;\nconst BUFFER_SIZE = 6;\nconst step = BUFFER_SIZE * bitSize;\n// let datetime = msg.receiveDate\n\n// let buffer = []\nlet buffer = new Array()\n\nconsole.log(\"========================\")\nconsole.log(\"spo2 process start...\")\n\nlet dcnt = 0;\nfor (let ccnt=0, l=tlen*2; ccnt<l; ccnt++) {\n    // subBufferにREDまたはIRの値をBUFFER SIZE分だけ格納する\n    let subBuffer = new Array()\n    for (let i = 0; i < BUFFER_SIZE; i++) {\n        // buffer[ccnt].push(parseInt( \n        //     String(input[dcnt * step + i * bitSize]) +\n        //     String(input[dcnt * step + i * bitSize + 1]) +\n        //     String(input[dcnt * step + i * bitSize + 2]) +\n        //     String(input[dcnt * step + i * bitSize + 3])\n        // ), 16)\n        let intItem = parseInt(\n            (String(input[dcnt * step + i * bitSize]) +\n            String(input[dcnt * step + i * bitSize + 1]) +\n            String(input[dcnt * step + i * bitSize + 2]) +\n            String(input[dcnt * step + i * bitSize + 3])), 16)\n            // String(input[dcnt * step + i * bitSize]) +\n            // String(input[dcnt * step + i * bitSize + 1]) +\n            // String(input[dcnt * step + i * bitSize + 2]) +\n            // String(input[dcnt * step + i * bitSize + 3]), 16)\n        subBuffer.push(intItem)\n    }\n    buffer.push(subBuffer)\n    dcnt += 1;\n}\n\nconsole.log(\"buffer: \" + buffer)\n\n// REDとIRのセットの数だけ回す\nfor (let i = 0; i < tlen; i++) {\n    // bufferの長さ分、REDとIRのペアを取り出して送信する\n    for (let j = 0; j < BUFFER_SIZE; j++){\n        // データの測定時刻を算出する\n        let measurementTime = new Date(currentDate.getTime() - samplingTime * ((tlen - i)*(BUFFER_SIZE - j) - 1))\n\n        console.log(\"RED: \" + buffer[i * 2][j] + \" IR: \" + buffer[i * 2 + 1][j])\n        if (buffer[i*2][j] == 0 || buffer[i*2+1][j] == 0){\n            node.done();\n            return null;\n        }\n        else{\n            let redMsg = {\n                Ndata: msg.Ndata,\n                payload: buffer[i*2][j],\n                timestamp: measurementTime\n            }\n            let irMsg = {\n                Ndata: msg.Ndata,\n                payload: buffer[i*2+1][j],\n                timestamp: measurementTime\n            }\n            node.send([redMsg, irMsg]);\n        }\n    }\n    node.done();\n}\n\n// for (let i = 0; i < BUFFER_SIZE; i++) {\n//     for (let j = 0; j < tlen; j++) {\n//         let measurementTime = new Date(currentDate.getTime() - (samplingTime * (BUFFER_SIZE - i - 1)))\n\n//         if (buffer[j * 2][i] == 0 || buffer[j * 2 + 1][i] == 0){\n//             node.done();\n//             return null;\n//         }\n//         else{\n\n//             let redMsg = {\n//                 Ndata: msg.Ndata,\n//                 payload: buffer[j * 2][i],\n//                 timestamp: measurementTime\n//             };\n//             let irMsg = {\n//                 Ndata: msg.Ndata,\n//                 payload: buffer[j * 2 + 1][i],\n//                 timestamp: measurementTime\n//             };\n//             node.send([redMsg, irMsg]);\n\n//         }\n//     };\n//     node.done();\n// }\n\nreturn null;\n",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 150,
        "y": 260,
        "wires": [
            [
                "a41263ea750b45d1",
                "da1640a613fed430"
            ],
            [
                "d04f95a734b79f7a",
                "3e908ed22509f98a"
            ]
        ]
    },
    {
        "id": "aef226ad7dbd90f6",
        "type": "function",
        "z": "51941ff1083ce014",
        "name": "calc deltaA",
        "func": "// 配列の平均を返す関数\nconst calcDC = (data) => {\n    const len = data.length;\n    if (!len){\n        return 0;\n    }\n    let dc = data.reduce((sum, val) => sum + val, 0) / len;\n    return dc;\n}\n\nconst calcACDC = (data) => {\n    let len = data.length;\n    if(!len){\n        return 0;\n    }\n    let dc = calcDC(data);\n    let ac = data.reduce((acc, val) => acc + Math.abs(val - dc), 0) / len;\n    return {ac, dc};\n}\n\nlet arr = msg.payload\nlet {ac, dc} = calcACDC(arr) \n\nif(dc == 0){\n    dc = 0.001 // 0除算対策\n    msg.payload = ac / dc\n} else {\n    msg.payload = ac / dc\n}\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 710,
        "y": 220,
        "wires": [
            [
                "b5926ab28b9843f1"
            ]
        ]
    },
