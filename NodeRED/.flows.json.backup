    {
        "id": "2cbb8f3dbfd9630c",
        "type": "function",
        "z": "997a3042cd0e7cd4",
        "name": "parse_PPG_data",
        "func": "let input = msg.payload;\nlet tlen = msg.Ndata.Len;\nlet hubDate = msg.hubDate\n\nconst BUFFER_SIZE = 3;\nconst samplingTime = 40; // ms\n\nif (tlen == 0) {\n    return null;\n}\n// ======= Nodeタイムスタンプ管理用 ======= \nconst contextName = {\n    // Hubのタイムスタンプを使用する\n    startDate: \"$parent.startDate_\" + msg.port,\n    startTime: \"$parent.startTime_\" + msg.port,\n}\n\nconst getCurrentDate = (timeStamp) => {\n    let startDate = flow.get(contextName.startDate)\n    let startTime = flow.get(contextName.startTime)\n    let diffTime = timeStamp - startTime\n    let currentDate = new Date(startDate + diffTime)\n    return currentDate\n}\n\n// ========================================================\n\nlet timeValue = parseInt(input[0] + input[1] + input[2] + input[3], 16)\n\n// contextデータを使用して時刻を算出する\nlet headDate = getCurrentDate(timeValue)\n\nlet ppgBuffer = input.slice(4)\nlet buffer = new Array()\n// lenのサイズに従ってBuffer配列を作成する\nfor (let cnt = 0; cnt < tlen; cnt++) {\n    buffer[cnt] = new Array()\n    for (let i = 0; i < BUFFER_SIZE; i++) {\n        buffer[cnt].push(ppgBuffer[i + BUFFER_SIZE * cnt])\n    }\n}\n\nfor (let cnt = 0; cnt<tlen; cnt++) {\n    let ppgValue = parseInt(buffer[cnt][0] + buffer[cnt][1] + buffer[cnt][2],16)\n    // PPGの範囲は0~100%のため、負数の処理は不要の想定\n    // if (ppgValue & 0x800000) ppgValue |= ~0xffffff; //24bit\n    \n    let measurementTime = new Date(headDate.getTime() + (samplingTime * cnt))\n    msg = {\n        Ndata: msg.Ndata,\n        payload: {\n            ppg: ppgValue,\n            Ndata: msg.Ndata,\n            timestamp: measurementTime\n        },\n        timestamp: measurementTime,\n        samplingTime: samplingTime,\n    }\n    node.send(msg);\n}\n\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 230,
        "y": 100,
        "wires": [
            []
        ]
    },
    {
        "id": "50eda4702f0c0418",
        "type": "function",
        "z": "a893cba93cb6f041",
        "name": "Imu_proc",
        "func": "let input = msg.payload;\nlet tlen = msg.Ndata.Len;\nlet hubDate = msg.hubDate\nconst samplingTime = 240\nconst BUFFER_SIZE = 16\n\nif (tlen == 0) {\n    return null;\n}\n\n// ======= Nodeタイムスタンプ管理用 ======= \nconst contextName = {\n    // Hubのタイムスタンプを使用\n    startDate: \"$parent.startDate_\" + msg.port,\n    startTime: \"$parent.startTime_\" + msg.port,\n}\n\nconst getCurrentDate = (timeStamp) => {\n    let startDate = flow.get(contextName.startDate)\n    let startTime = flow.get(contextName.startTime)\n    let diffTime = timeStamp - startTime\n    let currentDate = new Date(startDate + diffTime)\n    return currentDate\n}\n// =======================================\n\nlet buffer = []\n// lenのサイズに従ってBuffer配列を作成する\nfor (let cnt = 0; cnt < tlen; cnt++) {\n    buffer[cnt] = new Array()\n    for (let i = 0; i < BUFFER_SIZE; i++) {\n        buffer[cnt].push(input[i + BUFFER_SIZE * cnt])\n    }\n}\n\nlet measurementTime\nfor (let cnt = 0; cnt < tlen; cnt++) {\n    // 配列をgx~gz, ax~az, timestampに分ける\n    let gyro_x = parseInt(buffer[cnt][1],16)\n    if (gyro_x & 0x8000) gyro_x |= ~0xffff;\n    let gyro_y = parseInt(buffer[cnt][2],16)\n    if (gyro_y & 0x8000) gyro_y |= ~0xffff;\n    let gyro_z = parseInt(buffer[cnt][3],16)\n    if (gyro_z & 0x8000) gyro_z |= ~0xffff;\n    let acc_x = parseInt(buffer[cnt][5],16)\n    if (acc_x & 0x8000) acc_x |= ~0xffff;\n    let acc_y = parseInt(buffer[cnt][6],16)\n    if (acc_y & 0x8000) acc_y |= ~0xffff;\n    let acc_z = parseInt(buffer[cnt][7],16)\n    if (acc_z & 0x8000) acc_z |= ~0xffff;\n\n    //let gyro_x = parseInt(buffer[cnt][0] + buffer[cnt][1], 16)\n    //if (gyro_x & 0x8000) gyro_x |= ~0xffff;\n    //let gyro_y = parseInt(buffer[cnt][2] + buffer[cnt][3], 16)\n    //if (gyro_y & 0x8000) gyro_y |= ~0xffff;\n    //let gyro_z = parseInt(buffer[cnt][4] + buffer[cnt][5], 16)\n    //if (gyro_z & 0x8000) gyro_z |= ~0xffff;\n    //let acc_x = parseInt(buffer[cnt][6] + buffer[cnt][7], 16)\n    //if (acc_x & 0x8000) acc_x |= ~0xffff;\n    //let acc_y = parseInt(buffer[cnt][8] + buffer[cnt][9], 16)\n    //if (acc_y & 0x8000) acc_y |= ~0xffff;\n    //let acc_z = parseInt(buffer[cnt][10] + buffer[cnt][11], 16)\n    //if (acc_z & 0x8000) acc_z |= ~0xffff;\n    \n    let timeValue = parseInt(buffer[cnt][12] + buffer[cnt][13] + buffer[cnt][14] + buffer[cnt][15], 16)\n\n    // contextデータを使用して時刻を算出する\n    let measurementTime = getCurrentDate(timeValue)\n\n    let imuMsg = {\n        Ndata: msg.Ndata,\n        payload:{\n            gyro_x: gyro_x,\n            gyro_y: gyro_y,\n            gyro_z: gyro_z,\n            acc_x: acc_x,\n            acc_y: acc_y,\n            acc_z: acc_z\n        },\n        timestamp: measurementTime,\n        samplingTime: samplingTime,\n    }\n    node.send([imuMsg]);\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
