    {
        "id": "027b2023c26a2543",
        "type": "function",
        "z": "a99e786f7afaa3c5",
        "name": "FFT_filter",
        "func": "// ================= define complex functions =================\nconst expi = (theta) => {\n    return [Math.cos(theta), Math.sin(theta)]\n}\nconst iadd = ([ax, ay], [bx, by]) => {\n    return [ax + bx, ay + by]\n}\nconst isub = ([ax, ay], [bx, by]) => {\n    return [ax - bx, ay - by]\n}\nconst imul = ([ax, ay], [bx, by]) => {\n    return [ax * bx - ay * by, ax * by + ay * bx]\n}\nconst isum = (cs) => {\n    return cs.reduce((s, c) => iadd(s, c), [0, 0])\n}\nconst conj = ([x, y]) => {\n    return [x, -y];\n}\nconst revBit = (k,n0) =>{\n    if (k === 1) return n0;\n    const s1 = ((n0 & 0xaaaaaaaa) >>> 1) | ((n0 & 0x55555555) << 1);\n    if (k === 2) return s1;\n    const s2 = ((s1 & 0xcccccccc) >>> 2) | ((s1 & 0x33333333) << 2);\n    if (k <= 4) return s2 >>> (4 - k);\n    const s3 = ((s2 & 0xf0f0f0f0) >>> 4) | ((s2 & 0x0f0f0f0f) << 4);\n    if (k <= 8) return s3 >>> (8 - k);\n    const s4 = ((s3 & 0xff00ff00) >>> 8) | ((s3 & 0x00ff00ff) << 8);\n    if (k <= 16) return s4 >>> (16 - k);\n    const s5 = ((s4 & 0xffff0000) >>> 16) | ((s4 & 0x0000ffff) << 16);\n    return s5 >>> (32 - k);\n}\n\n// =============== define FFT function ===============\n\n/* basic fft function */\nconst fft_base = (c, T, N) => {\n    const k = Math.log2(N);\n    const rec = c.map((_, i) => c[revBit(k, i)]);\n    for (let Nh = 1; Nh < N; Nh *= 2) {\n        T /= 2;\n        for (let s = 0; s < N; s += Nh * 2) {\n            for (let i = 0; i < Nh; i++) {\n                const l = rec[s + i], re = imul(rec[s + i + Nh], expi(T * i));\n                [rec[s + i], rec[s + i + Nh]] = [iadd(l, re), isub(l, re)];\n            }\n        }\n    }\n    return rec\n}\n\n/* use base fft method */\nconst fft = (f) => {\n    const N = f.length, T = -2 * Math.PI;\n    return fft_base(f, T, N);\n}\nconst ifft = (F) => {\n    const N = F.length, T = 2 * Math.PI;\n    return fft_base(F, T, N).map(([r, i]) => [r / N, i / N]);\n}\n\n/* FFT by Bluestein's algorithm */\nconst fft_bluestein = (c, T, N) => {\n    const Nd = N * 2;\n    const bc = c.map((_, n) => expi(T * n * n / Nd));\n    const b = bc.map(conj);\n    const a = c.map((cn, n) => imul(cn, bc[n]));\n\n    const N2 = 1 << (32 - Math.clz32(Nd - 1));\n    const a2 = a.concat(Array(N2 - N).fill([0, 0]));\n    const b2 = b.concat(Array(N2 - Nd + 1).fill([0, 0]), b.slice(1).reverse());\n    const A2 = fft(a2);\n    const B2 = fft(b2);\n    const AB2 = A2.map((A2n, n) => imul(A2n, B2[n]));\n    const ab2 = ifft(AB2);\n    return bc.map((bcn, n) => imul(bcn, ab2[n]));\n}\n\n// データ長が2のべき乗か判定する関数\nconst isPowerOf2 = (n) =>{ \n    if(n===0) return false;\n    return (n & (n - 1)) === 0;\n}\n\nconst fft1 = (f) => {\n    const N = f.length, T = -2 * Math.PI;\n    // データ長によって使用するFFT関数を切り替える\n    const fft = isPowerOf2(N) ? fft_base : fft_bluestein\n    return fft(f, T, N);\n}\nconst ifft1 = (F) => {\n    const N = F.length, T = 2 * Math.PI;\n    // データ長によって使用するFFT関数を切り替える\n    const fft = isPowerOf2(N) ? fft_base : fft_bluestein\n    return fft(F, T, N).map(([r, i]) => [r / N, i / N]);\n}\n\n// ================================================\n\nlet input = msg.payload.data\nlet acf = msg.payload.acf\nlet timestamp = msg.timestamp\n\nif(input.length == 0){\n    return null\n}\n\n// サンプリング時間の設定\n// メッセージにサンプリング時間が設定されていた場合はそちらを採用する\n// ない場合は環境変数から取得を行う\n\nlet samplingTime = msg.samplingTime\nif(!samplingTime){\n    let SAMPLING_RATE = env.get(\"SAMPLING_RATE\")\n    if (!SAMPLING_RATE) {\n        node.error(\"sampling rate is not set\", msg);\n        return null;\n    } else{\n        samplingTime = parseInt(SAMPLING_RATE, 10)\n    }\n}\nif(samplingTime == 0){\n    node.error(\"sampling rate cannot be set to 0!\",msg);\n    return null;\n}\n\nconst f_resolution = 1 / (input.length * samplingTime/1000)\n\nlet F = fft1(input)\n\nlet PS = F.map((r, index) => [(f_resolution * index).toPrecision(6), Math.sqrt(r[0] ** 2 + r[1] ** 2)])\n\nlet PS_obj = {}\nPS.map((r)=> PS_obj[r[0]] = r[1])\n\nlet PSD_obj = {}\nPS.map((r) => {\n    PSD_obj[r[0]] = acf*(r[1] / f_resolution)    \n})\n\nlet fMsg = {\n    payload: F,\n    timestamp: timestamp,\n    Ndata: msg.Ndata, \n    tag: {\n        WINDOW_TYPE: env.get(\"WINDOW_TYPE\")\n    }\n}\nlet psMsg = {\n    payload: PS_obj ,\n    timestamp: timestamp,\n    Ndata: msg.Ndata,\n    tag: {\n        WINDOW_TYPE: env.get(\"WINDOW_TYPE\")\n    }\n}\nlet psdMsg = {\n    payload: PSD_obj,\n    timestamp: timestamp,\n    Ndata: msg.Ndata,\n    tag: {\n        WINDOW_TYPE: env.get(\"WINDOW_TYPE\")\n    }\n}\n\nnode.send([fMsg, psMsg, psdMsg]);\n\nreturn null;",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 800,
        "y": 180,
        "wires": [
            [],
            [],
            []
        ]
    },
