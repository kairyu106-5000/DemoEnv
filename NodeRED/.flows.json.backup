    {
        "id": "caf62c12fa399399",
        "type": "comment",
        "z": "b6720ac1884745ba",
        "name": "DB書き込み用のデータ作成",
        "info": "入力: \n```\nmsg: {\n    measurement: String,\n    Ndata: {\n        NodeName, String,\n        SensorType: String,\n    },\n    payload: JSON object,\n    timestamp: Date,\n}\n```\n\n出力:\n```\nmsg.payload: {\n    bucket: String,  // \"node-data\"\n    precision: String, // \"ms\"\n    data: [\n        {\n        measurement: String,\n        tags: {\n                \"NodeId\": String,\n                \"SensorType\": String,\n            },\n            fields: JSON object,\n            timestamp: number\n        }\n    ]\n}\n```",
        "x": 1120,
        "y": 1460,
        "wires": []
    },
    {
        "id": "0597da9ede82ae8b",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "Imu_proc_old",
        "func": "let input = msg.payload;\nlet tlen = msg.Ndata.Len;\nlet currentDate = msg.currentDate\nconst samplingTime = 240\nconst BUFFER_SIZE = 16\n\nif (tlen == 0) {\n    return null;\n}\n\n// ========== タイムスタンプ算出用 =========================================\nlet contextName = {\n    startDate: \"startDate_\" + msg.port,\n    startTime: \"startTime_\" + msg.port,\n}\n\nconst startDate = flow.get(contextName.startDate)\nconst startTime = flow.get(contextName.startTime)\n\n// const getCurrentDate = (timeStamp) => {\n//     let startDate = flow.get(contextName.startDate)\n//     let startTime = flow.get(contextName.startTime)\n//     let diffTime = timeStamp - startTime\n//     let currentDate = new Date(startDate + diffTime)\n//     return currentDate\n// }\n// =======================================================================\n\n// console.log(\"[\"+ new Date().getTime() + \"]\" + \"start Imu process...\")\n\n// let datetime = msg.receiveDate\n\nlet buffer = []\n// lenのサイズに従ってBuffer配列を作成する\nfor (let cnt = 0; cnt < tlen; cnt++) {\n    // buffer[cnt] = new Array(BUFFER_SIZE)\n    buffer[cnt] = new Array()\n    for (let i = 0; i < BUFFER_SIZE; i++) {\n        // buffer[cnt][i] = input[i + BUFFER_SIZE * cnt]\n        // buffer[cnt][i] = parseInt(buffer[cnt][i], 16)\n        buffer[cnt].push(input[i + BUFFER_SIZE * cnt])\n    }\n}\n\n// 配列をgx~gz, ax~az, timestampに分ける\nlet measurementTime\n// let firstImuTime\nfor (let cnt = 0; cnt < tlen; cnt++) {\n    // let dataTime = new Date(datetime.getTime() - (samplingTime * (tlen - cnt - 1)))\n    // dataTime = dataTime.getTime();\n    let gyro_x = parseInt(buffer[cnt][0] + buffer[cnt][1],16)\n    if (gyro_x & 0x8000) gyro_x |= ~0xffff;\n    let gyro_y = parseInt(buffer[cnt][2] + buffer[cnt][3],16)\n    if (gyro_y & 0x8000) gyro_y |= ~0xffff;\n    let gyro_z = parseInt(buffer[cnt][4] + buffer[cnt][5],16)\n    if (gyro_z & 0x8000) gyro_z |= ~0xffff;\n    let acc_x = parseInt(buffer[cnt][6] + buffer[cnt][7],16)\n    if (acc_x & 0x8000) acc_x |= ~0xffff;\n    let acc_y = parseInt(buffer[cnt][8] + buffer[cnt][9],16)\n    if (acc_y & 0x8000) acc_y |= ~0xffff;\n    let acc_z = parseInt(buffer[cnt][10] + buffer[cnt][11],16)\n    if (acc_z & 0x8000) acc_z |= ~0xffff;\n    \n    let timeValue = parseInt(buffer[cnt][12] + buffer[cnt][13] + buffer[cnt][14] + buffer[cnt][15], 16)\n\n    // Lenが2以上の場合、タイムスタンプの処理が必要\n    // if (0){\n    //     if (cnt == 0) {\n    //         measurementTime = new Date(currentDate)\n    //         // firstImuTime = timeValue\n    //         console.log(\"currentDate: \" + currentDate)\n    //     } else {\n    //         // measurementTime = new Date(currentDate.getTime() + (timeValue - firstImuTime))\n    //     }\n    // }\n    \n    // サンプリング時間を固定して算出する場合\n    // measurementTime = new Date(currentDate - samplingTime * ((tlen - cnt ) - 1)) \n\n    // データ内のタイムスタンプで時刻を算出する場合\n    measurementTime = new Date(startDate + (timeValue - startTime))\n\n    // console.log(\"mTime: \" + measurementTime.getTime())\n\n    let imuMsg = {\n        Ndata: msg.Ndata,\n        payload:{\n            gyro_x: gyro_x,\n            gyro_y: gyro_y,\n            gyro_z: gyro_z,\n            acc_x: acc_x,\n            acc_y: acc_y,\n            acc_z: acc_z\n        },\n        timestamp: measurementTime,\n        samplingTime: samplingTime,\n    }\n    node.send([imuMsg]);\n    // console.log(\"[\" + new Date().getTime() + \"]\" + \"send message \" + (cnt + 1) + \"/\" + tlen)\n}\n\n\n// console.log(\"[\" + new Date().getTime() + \"]\" + \"send complete.\")\n\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1160,
        "y": 1000,
        "wires": [
            [
                "70dbf1e2c2c07969"
            ]
        ]
    },
    {
        "id": "71aecfc44577360a",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "clear_startDate",
        "func": "let contextName = {\n    startDate: \"startDate_\" + msg.port,\n    startTime: \"startTime_\" + msg.port,\n    preTime: \"preTime_\" + msg.port,\n    nodeStartDate: \"startDate_nodeId_\" + msg.Ndata.NodeId,\n    nodeStartTime: \"startTime_nodeId_\" + msg.Ndata.NodeId,\n}\n\nflow.set(contextName.startDate, undefined)\nflow.set(contextName.startTime, undefined)\nflow.set(contextName.preTime, undefined)\nflow.set(contextName.nodeStartDate, undefined)\nflow.set(contextName.nodeStartTime, undefined)\n\nnode.log(\"clear startDate: \"+ msg.port)\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
