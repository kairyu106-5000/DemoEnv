    {
        "id": "8c5af822a97c77b3",
        "type": "function",
        "z": "b6720ac1884745ba",
        "name": "makeDataObject",
        "func": "// ========== measurement用データ ==========\nlet measurement = msg.measurement\n\n// ========== tag用データ ==========\n//const frame_count = msg.Ndata.FrameCount         //0~2\n//const recipient_id = msg.Ndata.RecipientID       //3\nconst node_id = msg.Ndata.NodeId                 //4\n//const ban_id = msg.Ndata.BanID                   //5\n//const fcs = msg.Ndata.FCS                        //6\n//const time_stamp = msg.Ndata.TimeStamp           //7~10\n//const sampling_timing = msg.Ndata.samplingTiming //11 \n//const sequence_num = msg.Ndata.SequenceNum       //12\nconst sensor_type = msg.Ndata.SensorType         //13\n//const frame_parity = msg.Ndata.FrameParity       //14,15\nconst tag = msg.tag;\n\nlet tagData = {\n    //\"FrameCount\": String(frame_count),           //0~2\n    //\"RecipientID\": String(recipient_id),         //3\n    \"NodeId\": String(node_id),                   //4\n    //\"BanID\": String(ban_id),                     //5\n    //\"FCS\": String(fcs),                          //6\n    //\"TimeStamp\": String(time_stamp),             //7~10\n    //\"samplingTiming\": String(sampling_timing),   //11\n    //\"SequenceNum\": String(sequence_num),         //12\n    \"SensorType\": String(sensor_type),           //13\n    //\"FrameParity\": String(frame_parity),         //14,15\n}\n\nif (tag) {\n    Object.assign(tagData, tag)\n}\n\n// ========== field用データ ==========\nlet fields = msg.payload\n\n// ========== timestamp用データ ==========\nlet timestamp = msg.timestamp\n\n// ========== データオブジェクト作成 ==========\nlet data = {\n    measurement: measurement,\n    tags: tagData,\n    fields: fields,\n    timestamp: timestamp.getTime()\n}\n\nmsg.payload = data\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
